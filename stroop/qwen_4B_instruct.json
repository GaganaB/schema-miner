{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.com/schemas/stroop-task-process",
    "title": "Stroop Task Process Schema",
    "type": "object",
    "properties": {
        "task_type": {
            "type": "string",
            "enum": [
                "standard",
                "emotional",
                "numerical",
                "spatial",
                "bilingual"
            ],
            "default": "standard"
        },
        "participants": {
            "type": "object",
            "properties": {
                "age_range": {
                    "type": "array",
                    "items": {
                        "type": "number", 
                        "minimum": 18, 
                        "maximum": 65,
                    },
                    "minItems": 2,
                    "maxItems": 2
                },
                "sample_size": {
                    "type": "integer",
                    "minimum": 20,
                    "maximum": 200,
                    },
                "population": {
                    "type": "string",
                    "enum": [
                        "adults",
                        "children",
                        "ADHD",
                        "depression",
                        "schizophrenia",
                        "frontal_lesion",
                        "aging"
                    ]
                }
            },
            "required": [
                "age_range",
                "sample_size",
                "population"
            ]
        },
        "stimuli": {
            "type": "object",
            "properties": {
                "conditions": {
                    "type": "object",
                    "enum": ["congruent", "incongruent", "neutral"]
                    },
                    "required": [
                        "congruent",
                        "incongruent",
                        "neutral"
                    ]
                },
                "color_set": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "red",
                        "blue",
                        "green",
                        "yellow"
                    ],
                    "minItems": 3,
                    "maxItems": 6
                }
            },
            "required": [
                "conditions",
                "color_set"
            ]
        },
        "task_instruction": {
            "type": "object",
            "properties": {
                "response_mapping": {
                    "type": "string",
                    "enum": [
                        "name_color",
                        "read_word"
                    ]
                },
                "response_modality": {
                    "type": "string",
                    "enum": [
                        "verbal",
                        "manual_keypress"
                    ]
                }
            },
            "required": [
                "response_mapping",
                "response_modality"
            ]
        },
        "experimental_settings": {
            "type": "object",
            "properties": {
                "stimulus_duration": {
                    "type": "integer",
                    "minimum": 500,
                    "maximum": 2000,
                    "enum": ["type": "ms"], 
                    "default": 1000
                },
                "inter_trial_interval": {
                    "type": "integer",
                    "minimum": 500,
                    "maximum": 1500,
                    "enum": ["type": "ms"], 
                    "default": 1000
                },
                "trials_per_condition": {
                    "type": "integer",
                    "minimum": 20,
                    "maximum": 100,
                    "default": 30
                },
                "stimulus_order": {
                    "type": "string",
                    "enum": [
                        "randomized",
                        "counterbalanced"
                    ],
                    "default": "randomized"
                },
                "environment": {
                    "type": "string",
                    "enum":[
                        "controlled lighting",
                        "minimal distraction"
                    ], 
                    "default": "controlled_lighting"
                }
            },
            "required": [
                "stimulus_duration",
                "inter_trial_interval",
                "trials_per_condition",
                "stimulus_order"
            ]
        },
        "instruments": {
            "type": "object",
            "properties": {
                "software": {
                    "type": "string",
                    "enum": [
                        "PsychoPy",
                        "E-Prime",
                        "MATLAB_Psychtoolbox"
                    ]
                },
                "response_device": {
                    "type": "string",
                    "enum": [
                        "keyboard",
                        "response_pad",
                        "voice_key"
                    ]
                },
                "display": {
                    "type": "object",
                    "properties": {
                        "luminance": {
                            "type": "number",
                            "enum":["type": "candelas per square meter (cd/m\u00b2)"],
                            "minimum": 0,
                            "maximum": 1000
                        },
                        "contrast": {
                            "type": "number",
                            "minimum": 1,
                            "maximum": 100
                        }
                    },
                    "required": [
                        "luminance",
                        "contrast"
                    ]
                },
                "reaction_time_precision": {
                    "type": "string",
                    "default": "millisecond"
                }
            },
            "required": [
                "software",
                "response_device",
                "display",
                "reaction_time_precision"
            ]
        },
        "outputs": {
            "type": "object",
            "properties": {
                "reaction_time_ms": {
                    "type": "object",
                    "properties": {
                        "type": "number",
                        "enum": ["type": "ms"]
                    },
                    "required": [
                        "congruent",
                        "incongruent",
                        "neutral"
                    ]
                },
                "error_rate": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 100
                },
                "interference_score": {
                    "type": "number",
                    "enum": ["type": "ms"],
                    "description": "Interference score calculated as RT(incongruent) \u2013 RT(congruent)"
                },
                "accuracy_adjusted_rt": {
                    "type": "number"
                }
            },
            "required": [
                "reaction_time_ms",
                "error_rate",
                "interference_score"
            ]
        },
        "behavioral_pattern": {
            "type": "object",
            "properties": {
                "expected_interference": {
                    "type": "boolean"
                },
                "expected_error_rate": {
                    "type": "boolean"
                },
                "robustness": {
                    "type": "string",
                    "enum": [
                        "robust",
                        "moderate",
                        "variable"
                    ],
                    "default": "robust"
                }
            },
            "required": [
                "expected_interference",
                "expected_error_rate"
            ]
        },
        "reliability": {
            "type": "object",
            "properties": {
                "test_retest_reliability": {
                    "type": "string"
                    "enum": [
                        "moderate",
                        "high",
                        "low"
                    ],
                    "default": "moderate"
                },
                "individual_difference_reliability": {
                    "type": "string",
                    "enum": [
                        "low",
                        "moderate",
                        "high"
                    ],
                    "default": "moderate"
                }
            }
        },
        "cognitive_constructs_measured": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Cognitive processes measured by the Stroop task.",
            "default": [
                "selective_attention",
                "executive_control",
                "inhibitory_control",
                "processing_speed",
                "conflict_monitoring"
            ],
            "enum": [
                "selective_attention",
                "executive_control",
                "inhibitory_control",
                "processing_speed",
                "conflict_monitoring"
            ]
        },
        "data_analysis_norms": {
            "type": "object",
            "properties": {
                "outlier_exclusion": {
                    "type": "object",
                    "properties": {
                        "method": {
                            "type": "string",
                            "enum": [
                                "two_sd",
                                "below_200_ms",
                                "above_3000_ms"
                            ]
                        }
                    }
                },
                "incorrect_trial_exclusion": {
                    "type": "boolean"
                },
                "analysis_method": {
                    "type": "string",
                    "enum": [
                        "within_subject_ANOVA",
                        "mixed_effects_modeling"
                    ]
                }
            },
            "required": [
                "outlier_exclusion",
                "incorrect_trial_exclusion",
                "analysis_method"
            ]
        },
        "validity": {
            "type": "object",
            "properties": {
                "construct_validity": {
                    "type": "string",
                    "enum": [
                        "strong",
                        "moderate",
                        "weak"
                    ],
                    "default": "strong"
                },
                "sensitivity": {
                    "type": "string",
                    "enum": [
                        "high",
                        "moderate",
                        "low"
                    ],
                    "default": "high"
                },
                "influencing_factors": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "reading_proficiency",
                        "language_familiarity"
                    ]
                }
            },
            "required": [
                "construct_validity",
                "sensitivity",
                "influencing_factors"
            ]
        },
        "neuroimaging": {
            "type": "object",
            "properties": {
                "eeg": {
                    "type": "object",
                    "properties": {
                        "channels": {
                            "type": "integer",
                            "minimum": 32,
                            "maximum": 128,
                        },
                        "sampling_rate": {
                            "type": "integer",
                            "minimum": 500,
                            "maximum": 1000,
                            "enum": ["type": "Hz"]
                        },
                        "impedance": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 10000,
                            "enum": ["type": "ohms"]
                        },
                        "reference": {
                            "type": "string",
                            "enum": [
                                "linked_mastoids",
                                "average_reference"
                            ]
                        },
                        "eog_channels": {
                            "type": "boolean"
                        },
                        "event_markers": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "default": [
                                "stimulus_onset",
                                "response_onset",
                                "accuracy"
                            ]
                        },
                        "components": {
                            "type": "object",
                            "properties": {
                                "n200": {
                                    "type": "object",
                                    "properties": {
                                        "latency": {
                                            "type": "string",
                                            "default": "200-350 ms"
                                        },
                                        "amplitude": {
                                            "type": "string"
                                        }
                                    }
                                },
                                "n450": {
                                    "type": "object",
                                    "properties": {
                                        "latency": {
                                            "type": "string",
                                            "default": "350-500 ms"
                                        },
                                        "amplitude": {
                                            "type": "string"
                                        }
                                    }
                                },
                                "p300": {
                                    "type": "object",
                                    "properties": {
                                        "latency": {
                                            "type": "string",
                                            "default": "300-600 ms"
                                        },
                                        "amplitude": {
                                            "type": "string"
                                        }
                                    }
                                },
                                "lpc": {
                                    "type": "object",
                                    "properties": {
                                        "latency": {
                                            "type": "string",
                                            "default": ">500 ms"
                                        },
                                        "amplitude": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "required": [
                        "channels",
                        "sampling_rate",
                        "impedance",
                        "reference",
                        "eog_channels",
                        "event_markers",
                        "components"
                    ]
                },
                "fMRI": {
                    "type": "object",
                    "properties": {
                        "scanner": {
                            "type": "string",
                            "default": "3T"
                        },
                        "tr": {
                            "type": "integer",
                            "minimum": 2000,
                            "maximum": 2500,
                            "enum": ["type": "ms"]
                        },
                        "te": {
                            "type": "integer",
                            "minimum": 30,
                            "maximum": 100,
                            "enum": ["type": "ms"]
                        },
                        "voxel_size": {
                            "type": "string",
                            "enum": ["type": "mm"],
                            "default": "2-3 mm"
                        },
                        "design": {
                            "type": "string",
                            "enum": [
                                "event_related",
                                "block_design"
                            ],
                            "default": "event_related"
                        },
                        "key_regions": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "default": [
                                "anterior_cingulate_cortex",
                                "dorsolateral_prefrontal_cortex",
                                "inferior_frontal_gyrus",
                                "parietal_cortex",
                                "basal_ganglia"
                            ]
                        },
                        "expected_contrast": {
                            "type": "string",
                            "default": "incongruent > congruent"
                        }
                    },
                    "required": [
                        "scanner",
                        "tr",
                        "te",
                        "voxel_size",
                        "design",
                        "key_regions",
                        "expected_contrast"
                    ]
                },
                "advanced_analysis": {
                    "type": "object",
                    "properties": {
                        "functional_connectivity": {
                            "type": "string",
                            "enum": [
                                "PPI",
                                "fronto_parietal_network",
                                "EEG_coherence",
                                "effective_connectivity"
                            ]
                        },
                        "neural_coupling_measures": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "default": [
                                "interference_score_vs_ACC_activation",
                                "N450_amplitude_vs_RT_slowing",
                                "theta_power_vs_error_likelihood",
                                "trial_by_trial_conflict_adaptation"
                            ]
                        },
                        "neurocomputational_model": {
                            "type": "string",
                            "enum": [
                                "drift_diffusion_modeling",
                                "botvinick_framework"
                            ]
                        },
                        "key_model_variables": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "default": [
                                "drift_rate",
                                "decision_threshold",
                                "conflict_signal_strength",
                                "control_gain_modulation"
                            ]
                        }
                    },
                    "required": [
                        "functional_connectivity",
                        "neural_coupling_measures",
                        "neurocomputational_model",
                        "key_model_variables"
                    ]
                }
            },
            "required": [
                "eeg",
                "fMRI",
                "advanced_analysis"
            ]
        },
        "clinical_applications": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "default": [
                "ADHD",
                "depression",
                "schizophrenia",
                "frontal_lobes_lesion",
                "aging"
            ],
            "enum": [
                "ADHD",
                "depression",
                "schizophrenia",
                "frontal_lobes_lesion",
                "aging"
            ]
        }
    },
    "required": [
        "task_type",
        "participants",
        "stimuli",
        "task_instruction",
        "experimental_settings",
        "instruments",
        "outputs",
        "behavioral_pattern",
        "reliability",
        "cognitive_constructs_measured",
        "data_analysis_norms",
        "validity",
        "neuroimaging",
        "clinical_applications"
    ],
    "additionalProperties": false
}

