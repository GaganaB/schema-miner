{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "StroopTaskProcess",
    "description": "A comprehensive JSON schema representing the structure, parameters, and outputs of a Stroop task experiment, including behavioral, neuroimaging, and computational modeling components. Designed for consistency with scientific standards and expert feedback.",
    "type": "object",
    "properties": {
        "taskType": {
            "type": "string",
            "enum": [
                "Standard Stroop",
                "Emotional Stroop",
                "Numerical Stroop",
                "Spatial Stroop",
                "Bilingual Stroop",
                "Clinical Adaptation"
            ],
            "description": "The variant of the Stroop task being implemented. Determines stimulus content and cognitive demands."
        },
        "stimuli": {
            "type": "object",
            "properties": {
                "stimulusTypes": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "Congruent",
                            "Incongruent",
                            "Neutral"
                        ]
                    },
                    "minItems": 1,
                    "description": "List of stimulus types used in the task. Congruent: word matches ink color; Incongruent: word mismatches ink color; Neutral: non-color word or symbol in colored ink."
                },
                "colorSet": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "red",
                            "blue",
                            "green",
                            "yellow",
                            "black",
                            "white"
                        ]
                    },
                    "minItems": 3,
                    "maxItems": 6,
                    "description": "Set of basic colors used in the task. Typically 3\u20136 colors, commonly red, blue, green, yellow."
                },
                "wordContent": {
                    "type": "object",
                    "properties": {
                        "congruent": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "description": "List of color words that match their ink color (e.g., 'RED' in red ink)."
                        },
                        "incongruent": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "description": "List of color words that do not match their ink color (e.g., 'RED' in blue ink)."
                        },
                        "neutral": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "description": "List of non-color words or symbols used as neutral stimuli (e.g., 'XXXX')."
                        }
                    },
                    "required": [
                        "congruent",
                        "incongruent",
                        "neutral"
                    ]
                },
                "stimulusDuration": {
                    "type": "number",
                    "minimum": 500,
                    "maximum": 2000,
                    "unit": "milliseconds",
                    "description": "Duration of each stimulus presentation in milliseconds. Often presented until response is made."
                },
                "interTrialInterval": {
                    "type": "number",
                    "minimum": 500,
                    "maximum": 1500,
                    "unit": "milliseconds",
                    "description": "Time between the offset of one trial and the onset of the next trial."
                },
                "trialCountPerCondition": {
                    "type": "integer",
                    "minimum": 20,
                    "maximum": 100,
                    "description": "Number of trials per stimulus condition (congruent, incongruent, neutral). Typically 20\u2013100+."
                },
                "stimulusOrder": {
                    "type": "string",
                    "enum": [
                        "randomized",
                        "counterbalanced"
                    ],
                    "description": "Order in which stimuli are presented across trials. Randomization reduces order effects; counterbalancing ensures equal exposure across conditions."
                }
            },
            "required": [
                "stimulusTypes",
                "colorSet",
                "wordContent",
                "stimulusDuration",
                "interTrialInterval",
                "trialCountPerCondition",
                "stimulusOrder"
            ]
        },
        "taskInstruction": {
            "type": "object",
            "properties": {
                "responseMapping": {
                    "type": "string",
                    "enum": [
                        "Name ink color (ignore word)",
                        "Read word (ignore ink color)"
                    ],
                    "description": "The primary instruction given to participants. Most common is naming ink color while ignoring word meaning."
                },
                "responseModality": {
                    "type": "string",
                    "enum": [
                        "verbal",
                        "manual"
                    ],
                    "description": "How participants provide their response. Verbal: spoken response recorded via voice key; Manual: keypress mapped to colors."
                },
                "responseKeyMapping": {
                    "type": "object",
                    "description": "Mapping of response keys to colors (if manual response). Only applicable when responseModality is 'manual'.",
                    "properties": {
                        "red": {
                            "type": "string",
                            "description": "Key assigned to red ink."
                        },
                        "blue": {
                            "type": "string",
                            "description": "Key assigned to blue ink."
                        },
                        "green": {
                            "type": "string",
                            "description": "Key assigned to green ink."
                        },
                        "yellow": {
                            "type": "string",
                            "description": "Key assigned to yellow ink."
                        },
                        "black": {
                            "type": "string",
                            "description": "Key assigned to black ink."
                        },
                        "white": {
                            "type": "string",
                            "description": "Key assigned to white ink."
                        }
                    },
                    "additionalProperties": false
                }
            },
            "required": [
                "responseMapping",
                "responseModality"
            ]
        },
        "experimentalSettings": {
            "type": "object",
            "properties": {
                "environment": {
                    "type": "object",
                    "properties": {
                        "lighting": {
                            "type": "string",
                            "enum": [
                                "controlled",
                                "dim",
                                "standard"
                            ],
                            "description": "Lighting conditions during the experiment to minimize distraction."
                        },
                        "distractionLevel": {
                            "type": "string",
                            "enum": [
                                "minimal",
                                "none",
                                "low"
                            ],
                            "description": "Level of environmental distractions allowed during testing."
                        }
                    },
                    "required": [
                        "lighting",
                        "distractionLevel"
                    ]
                },
                "displayCalibration": {
                    "type": "object",
                    "properties": {
                        "luminance": {
                            "type": "number",
                            "minimum": 0,
                            "unit": "cd/m\u00b2",
                            "description": "Calibrated luminance of the display screen."
                        },
                        "contrast": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1,
                            "unit": "ratio",
                            "description": "Contrast ratio of the display (e.g., 0.8 means 80% contrast)."
                        },
                        "resolution": {
                            "type": "string",
                            "description": "Screen resolution (e.g., '1920x1080')."
                        }
                    },
                    "required": [
                        "luminance",
                        "contrast",
                        "resolution"
                    ]
                }
            },
            "required": [
                "environment",
                "displayCalibration"
            ]
        },
        "instruments": {
            "type": "object",
            "properties": {
                "software": {
                    "type": "string",
                    "enum": [
                        "PsychoPy",
                        "E-Prime",
                        "MATLAB Psychtoolbox",
                        "OpenSesame",
                        "Presentation",
                        "Custom"
                    ],
                    "description": "Experimental software used to present stimuli and record responses."
                },
                "responseDevice": {
                    "type": "string",
                    "enum": [
                        "standard keyboard",
                        "response pad",
                        "touchscreen",
                        "custom"
                    ],
                    "description": "Physical device used for participant responses."
                },
                "voiceKey": {
                    "type": "object",
                    "properties": {
                        "microphone": {
                            "type": "string",
                            "description": "Model or type of microphone used for voice recording."
                        },
                        "samplingRate": {
                            "type": "integer",
                            "minimum": 16000,
                            "unit": "Hz",
                            "description": "Sampling rate of the audio recording system."
                        }
                    },
                    "required": [
                        "microphone",
                        "samplingRate"
                    ]
                },
                "rtPrecision": {
                    "type": "string",
                    "enum": [
                        "millisecond",
                        "microsecond"
                    ],
                    "description": "Precision of reaction time measurement. Millisecond resolution is standard."
                }
            },
            "required": [
                "software",
                "responseDevice",
                "voiceKey",
                "rtPrecision"
            ]
        },
        "primaryOutputs": {
            "type": "object",
            "properties": {
                "reactionTime": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "trialId": {
                                "type": "integer",
                                "description": "Unique identifier for the trial."
                            },
                            "condition": {
                                "type": "string",
                                "enum": [
                                    "Congruent",
                                    "Incongruent",
                                    "Neutral"
                                ],
                                "description": "Type of stimulus condition for this trial."
                            },
                            "rtMs": {
                                "type": "number",
                                "minimum": 0,
                                "unit": "milliseconds",
                                "description": "Reaction time in milliseconds."
                            },
                            "accuracy": {
                                "type": "boolean",
                                "description": "Whether the response was correct."
                            },
                            "responseKey": {
                                "type": "string",
                                "description": "Key pressed or word spoken."
                            }
                        },
                        "required": [
                            "trialId",
                            "condition",
                            "rtMs",
                            "accuracy",
                            "responseKey"
                        ]
                    },
                    "description": "List of all reaction times and accuracy outcomes per trial."
                },
                "interferenceScore": {
                    "type": "number",
                    "minimum": 0,
                    "unit": "milliseconds",
                    "description": "Computed interference score: RT(incongruent) - RT(congruent). Measures cognitive conflict."
                },
                "errorRate": {
                    "type": "object",
                    "properties": {
                        "congruent": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 100,
                            "unit": "%",
                            "description": "Percentage of incorrect responses in congruent trials."
                        },
                        "incongruent": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 100,
                            "unit": "%",
                            "description": "Percentage of incorrect responses in incongruent trials."
                        },
                        "neutral": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 100,
                            "unit": "%",
                            "description": "Percentage of incorrect responses in neutral trials."
                        }
                    },
                    "required": [
                        "congruent",
                        "incongruent",
                        "neutral"
                    ]
                },
                "accuracyAdjustedRT": {
                    "type": "number",
                    "minimum": 0,
                    "unit": "milliseconds",
                    "description": "Optional composite metric combining RT and accuracy (e.g., inverse accuracy RT)."
                }
            },
            "required": [
                "reactionTime",
                "interferenceScore",
                "errorRate"
            ]
        },
        "expectedBehavior": {
            "type": "object",
            "properties": {
                "rtPattern": {
                    "type": "string",
                    "enum": [
                        "incongruent > congruent",
                        "incongruent < congruent",
                        "no difference"
                    ],
                    "description": "Expected pattern of reaction times across conditions. Incongruent trials should have longer RTs."
                },
                "errorPattern": {
                    "type": "string",
                    "enum": [
                        "incongruent > congruent",
                        "incongruent < congruent",
                        "no difference"
                    ],
                    "description": "Expected pattern of error rates. Incongruent trials typically have higher error rates."
                },
                "robustness": {
                    "type": "boolean",
                    "description": "Whether the interference effect is expected to be robust across age groups and cultures."
                }
            },
            "required": [
                "rtPattern",
                "errorPattern",
                "robustness"
            ]
        },
        "reliability": {
            "type": "object",
            "properties": {
                "testRetestReliability": {
                    "type": "string",
                    "enum": [
                        "low",
                        "moderate",
                        "high"
                    ],
                    "description": "Reliability of the task across repeated administrations. Varies by scoring method."
                },
                "individualDifferenceReliability": {
                    "type": "string",
                    "enum": [
                        "low",
                        "moderate",
                        "high"
                    ],
                    "description": "Reliability of individual differences in performance. Depends on number of trials."
                }
            },
            "required": [
                "testRetestReliability",
                "individualDifferenceReliability"
            ]
        },
        "cognitiveConstructs": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "Selective attention",
                    "Executive control",
                    "Inhibitory control",
                    "Processing speed",
                    "Conflict monitoring"
                ]
            },
            "description": "Cognitive constructs measured by the Stroop task."
        },
        "dataAnalysis": {
            "type": "object",
            "properties": {
                "outlierExclusion": {
                    "type": "object",
                    "properties": {
                        "method": {
                            "type": "string",
                            "enum": [
                                "\u00b12SD",
                                "200ms-3000ms"
                            ],
                            "description": "Method used to exclude reaction time outliers."
                        },
                        "threshold": {
                            "type": "object",
                            "properties": {
                                "min": {
                                    "type": "number",
                                    "minimum": 0,
                                    "unit": "milliseconds"
                                },
                                "max": {
                                    "type": "number",
                                    "minimum": 0,
                                    "unit": "milliseconds"
                                }
                            },
                            "required": [
                                "min",
                                "max"
                            ]
                        }
                    },
                    "required": [
                        "method",
                        "threshold"
                    ]
                },
                "incorrectTrialRemoval": {
                    "type": "boolean",
                    "description": "Whether incorrect-response trials are excluded from RT analysis."
                },
                "statisticalModel": {
                    "type": "string",
                    "enum": [
                        "within-subject ANOVA",
                        "mixed-effects modeling",
                        "linear regression",
                        "Bayesian models"
                    ],
                    "description": "Primary statistical method used to analyze data."
                }
            },
            "required": [
                "outlierExclusion",
                "incorrectTrialRemoval",
                "statisticalModel"
            ]
        },
        "validity": {
            "type": "object",
            "properties": {
                "constructValidity": {
                    "type": "string",
                    "enum": [
                        "strong",
                        "moderate",
                        "weak"
                    ],
                    "description": "Strength of evidence that the task measures interference control."
                },
                "sensitivityToDysfunction": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "frontal lobe dysfunction",
                            "ADHD",
                            "depression",
                            "schizophrenia",
                            "aging",
                            "language proficiency"
                        ]
                    },
                    "description": "Clinical or demographic factors that influence Stroop performance."
                }
            },
            "required": [
                "constructValidity",
                "sensitivityToDysfunction"
            ]
        },
        "neuroimaging": {
            "type": "object",
            "properties": {
                "eeg": {
                    "type": "object",
                    "properties": {
                        "setup": {
                            "type": "object",
                            "properties": {
                                "channels": {
                                    "type": "integer",
                                    "minimum": 32,
                                    "maximum": 128,
                                    "description": "Number of EEG channels (e.g., 32\u2013128)."
                                },
                                "system": {
                                    "type": "string",
                                    "enum": [
                                        "10-20",
                                        "high-density"
                                    ],
                                    "description": "Electrode placement system."
                                },
                                "samplingRate": {
                                    "type": "integer",
                                    "minimum": 500,
                                    "maximum": 1000,
                                    "unit": "Hz",
                                    "description": "EEG sampling frequency."
                                },
                                "impedance": {
                                    "type": "number",
                                    "minimum": 0,
                                    "maximum": 10000,
                                    "unit": "k\u03a9",
                                    "description": "Electrode impedance (target: <5\u201310 k\u03a9)."
                                },
                                "reference": {
                                    "type": "string",
                                    "enum": [
                                        "linked mastoids",
                                        "average reference"
                                    ],
                                    "description": "Reference electrode configuration."
                                },
                                "eogChannels": {
                                    "type": "integer",
                                    "minimum": 1,
                                    "description": "Number of EOG channels used for blink correction."
                                }
                            },
                            "required": [
                                "channels",
                                "system",
                                "samplingRate",
                                "impedance",
                                "reference",
                                "eogChannels"
                            ]
                        },
                        "eventMarkers": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "stimulus onset",
                                    "response onset",
                                    "accuracy coding"
                                ]
                            },
                            "description": "Types of event markers recorded during EEG acquisition."
                        },
                        "keyComponents": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "component": {
                                        "type": "string",
                                        "enum": [
                                            "N200",
                                            "N450",
                                            "P300",
                                            "LPC"
                                        ],
                                        "description": "Neural component of interest."
                                    },
                                    "latencyRange": {
                                        "type": "object",
                                        "properties": {
                                            "min": {
                                                "type": "number",
                                                "unit": "milliseconds"
                                            },
                                            "max": {
                                                "type": "number",
                                                "unit": "milliseconds"
                                            }
                                        },
                                        "required": [
                                            "min",
                                            "max"
                                        ]
                                    },
                                    "interpretation": {
                                        "type": "string",
                                        "description": "Functional interpretation of the component."
                                    }
                                },
                                "required": [
                                    "component",
                                    "latencyRange",
                                    "interpretation"
                                ]
                            }
                        },
                        "expectedPatterns": {
                            "type": "object",
                            "properties": {
                                "incongruentVsCongruent": {
                                    "type": "string",
                                    "enum": [
                                        "larger N450 amplitude",
                                        "greater fronto-central activation",
                                        "increased theta power"
                                    ],
                                    "description": "Expected neural differences between incongruent and congruent trials."
                                }
                            },
                            "required": [
                                "incongruentVsCongruent"
                            ]
                        }
                    },
                    "required": [
                        "setup",
                        "eventMarkers",
                        "keyComponents",
                        "expectedPatterns"
                    ]
                },
                "fmri": {
                    "type": "object",
                    "properties": {
                        "scanner": {
                            "type": "object",
                            "properties": {
                                "fieldStrength": {
                                    "type": "number",
                                    "minimum": 1,
                                    "maximum": 7,
                                    "unit": "Tesla",
                                    "description": "MRI scanner field strength (e.g., 3T)."
                                },
                                "tr": {
                                    "type": "number",
                                    "minimum": 2000,
                                    "maximum": 2500,
                                    "unit": "milliseconds",
                                    "description": "Repetition time (TR) for fMRI scans."
                                },
                                "te": {
                                    "type": "number",
                                    "minimum": 10,
                                    "maximum": 50,
                                    "unit": "milliseconds",
                                    "description": "Echo time (TE)."
                                },
                                "voxelSize": {
                                    "type": "number",
                                    "minimum": 1,
                                    "maximum": 5,
                                    "unit": "mm",
                                    "description": "Isotropic voxel size (e.g., 2\u20133 mm)."
                                },
                                "coverage": {
                                    "type": "string",
                                    "enum": [
                                        "whole-brain",
                                        "targeted"
                                    ],
                                    "description": "Extent of brain coverage."
                                }
                            },
                            "required": [
                                "fieldStrength",
                                "tr",
                                "te",
                                "voxelSize",
                                "coverage"
                            ]
                        },
                        "design": {
                            "type": "string",
                            "enum": [
                                "event-related",
                                "block"
                            ],
                            "description": "Experimental design used in fMRI. Event-related preferred for conflict separation."
                        },
                        "keyRegions": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "region": {
                                        "type": "string",
                                        "enum": [
                                            "Anterior Cingulate Cortex (ACC)",
                                            "Dorsolateral Prefrontal Cortex (DLPFC)",
                                            "Inferior Frontal Gyrus",
                                            "Parietal Cortex",
                                            "Basal Ganglia"
                                        ],
                                        "description": "Brain region involved in conflict processing."
                                    },
                                    "functionalRole": {
                                        "type": "string",
                                        "description": "Role of the region in Stroop task performance."
                                    }
                                },
                                "required": [
                                    "region",
                                    "functionalRole"
                                ]
                            }
                        },
                        "expectedContrast": {
                            "type": "string",
                            "enum": [
                                "incongruent > congruent"
                            ],
                            "description": "Primary contrast used to identify brain activation related to conflict processing."
                        }
                    },
                    "required": [
                        "scanner",
                        "design",
                        "keyRegions",
                        "expectedContrast"
                    ]
                },
                "connectivityAnalysis": {
                    "type": "object",
                    "properties": {
                        "fMRI": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "PPI analysis",
                                    "functional connectivity",
                                    "fronto-parietal network engagement"
                                ]
                            },
                            "description": "Advanced fMRI connectivity analyses."
                        },
                        "EEG": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "theta-band coherence",
                                    "phase synchronization",
                                    "EEG-fMRI fusion"
                                ]
                            },
                            "description": "Advanced EEG connectivity analyses."
                        },
                        "effectiveConnectivity": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "DCM",
                                    "Granger causality",
                                    "dynamic causal modeling"
                                ]
                            },
                            "description": "Methods for modeling directed influence between brain regions."
                        }
                    },
                    "required": [
                        "fMRI",
                        "EEG",
                        "effectiveConnectivity"
                    ]
                },
                "behavioralNeuralCoupling": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "correlation between interference score and ACC activation",
                            "N450 amplitude vs. reaction time slowing",
                            "theta power increase vs. error likelihood",
                            "trial-by-trial conflict adaptation (Gratton effect)"
                        ]
                    },
                    "description": "Common derived measures linking behavior and neural activity."
                }
            },
            "required": [
                "eeg",
                "fmri",
                "connectivityAnalysis",
                "behavioralNeuralCoupling"
            ]
        },
        "neurocomputationalModeling": {
            "type": "object",
            "properties": {
                "modelType": {
                    "type": "string",
                    "enum": [
                        "Drift Diffusion Model (DDM)",
                        "Conflict Monitoring Model (Botvinick)",
                        "Parallel Processing with Inhibition"
                    ],
                    "description": "Computational model used to simulate Stroop performance."
                },
                "keyVariables": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "drift rate",
                            "decision threshold",
                            "conflict signal strength",
                            "control gain modulation"
                        ]
                    },
                    "description": "Core parameters in the model that influence response latency and accuracy."
                },
                "modelFit": {
                    "type": "object",
                    "properties": {
                        "fitMethod": {
                            "type": "string",
                            "enum": [
                                "maximum likelihood",
                                "Bayesian estimation"
                            ],
                            "description": "Method used to estimate model parameters."
                        },
                        "goodnessOfFit": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1,
                            "description": "R\u00b2 or other fit metric."
                        }
                    },
                    "required": [
                        "fitMethod",
                        "goodnessOfFit"
                    ]
                }
            },
            "required": [
                "modelType",
                "keyVariables",
                "modelFit"
            ]
        },
        "clinicalApplications": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "ADHD research",
                    "depression (emotional Stroop bias)",
                    "schizophrenia (impaired conflict monitoring)",
                    "frontal lobe lesion studies",
                    "aging research (executive control decline)"
                ]
            },
            "description": "Clinical populations or conditions where Stroop paradigms are used for assessment or research."
        }
    },
    "required": [
        "taskType",
        "stimuli",
        "taskInstruction",
        "experimentalSettings",
        "instruments",
        "primaryOutputs",
        "expectedBehavior",
        "reliability",
        "cognitiveConstructs",
        "dataAnalysis",
        "validity",
        "neuroimaging",
        "neurocomputationalModeling",
        "clinicalApplications"
    ]
