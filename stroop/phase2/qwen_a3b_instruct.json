{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "StroopTaskProcess",
    "type": "object",
    "properties": {
        "taskType": {
            "type": "string",
            "enum": [
                "Standard Stroop",
                "Emotional Stroop",
                "Numerical Stroop",
                "Spatial Stroop",
                "Bilingual Stroop",
                "Clinical Adaptation"
            ]
        },
        "stimuli": {
            "type": "object",
            "properties": {
                "stimulusTypes": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "Congruent",
                            "Incongruent",
                            "Neutral"
                        ]
                    },
                    "minItems": 1
                },
                "colorSet": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "red",
                            "blue",
                            "green",
                            "yellow",
                            "black",
                            "white"
                        ]
                    },
                    "minItems": 3,
                    "maxItems": 6
                },
                "wordContent": {
                    "type": "object",
                    "properties": {
                        "enum": [
                            "Congruent",
                            "Incongruent",
                            "Neutral"
                        ], 
                        "type": "array",
                            "items": {
                                "type": "string"
                            },
                    },
                    "required": [
                        "congruent",
                        "incongruent",
                        "neutral"
                    ]
                },
                "stimulusDuration": {
                    "type": "number",
                    "minimum": 500,
                    "maximum": 2000,
                    "unit": "milliseconds"
                },
                "interTrialInterval": {
                    "type": "number",
                    "minimum": 500,
                    "maximum": 1500,
                    "unit": "milliseconds"
                },
                "trialCountPerCondition": {
                    "type": "integer",
                    "minimum": 20,
                    "maximum": 100
                },
                "stimulusOrder": {
                    "type": "string",
                    "enum": [
                        "randomized",
                        "counterbalanced"
                    ]
                }
            },
            "required": [
                "stimulusTypes",
                "colorSet",
                "wordContent",
                "stimulusDuration",
                "interTrialInterval",
                "trialCountPerCondition",
                "stimulusOrder"
            ]
        },
        "taskInstruction": {
            "type": "object",
            "properties": {
                "responseMapping": {
                    "type": "string",
                    "enum": [
                        "Name ink color (ignore word)",
                        "Read word (ignore ink color)"
                    ]
                },
                "responseModality": {
                    "type": "string",
                    "enum": [
                        "verbal",
                        "manual"
                    ]
                },
                "responseKeyMapping": {
                    "type": "object",
                    "properties": {
                        "red": { "type": "string" },
                        "blue": { "type": "string" },
                        "green": { "type": "string" },
                        "yellow": { "type": "string" },
                        "black": { "type": "string" },
                        "white": { "type": "string" }
                    },
                    "additionalProperties": false
                }
            },
            "required": [
                "responseMapping",
                "responseModality"
            ]
        },
        "experimentalSettings": {
            "type": "object",
            "properties": {
                "environment": {
                    "type": "object",
                    "properties": {
                        "lighting": {
                            "type": "string",
                            "enum": [
                                "controlled",
                                "dim",
                                "standard"
                            ]
                        },
                        "distractionLevel": {
                            "type": "string",
                            "enum": [
                                "minimal",
                                "none",
                                "low"
                            ]
                        }
                    },
                    "required": [
                        "lighting",
                        "distractionLevel"
                    ]
                },
                "displayCalibration": {
                    "type": "object",
                    "properties": {
                        "luminance": {
                            "type": "number",
                            "minimum": 0,
                            "unit": "cd/m²"
                        },
                        "contrast": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1,
                            "unit": "ratio"
                        },
                        "resolution": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "luminance",
                        "contrast",
                        "resolution"
                    ]
                }
            },
            "required": [
                "environment",
                "displayCalibration"
            ]
        },
        "instruments": {
            "type": "object",
            "properties": {
                "software": {
                    "type": "string",
                    "enum": [
                        "PsychoPy",
                        "E-Prime",
                        "MATLAB Psychtoolbox",
                        "OpenSesame",
                        "Presentation",
                        "Custom"
                    ]
                },
                "responseDevice": {
                    "type": "string",
                    "enum": [
                        "standard keyboard",
                        "response pad",
                        "touchscreen",
                        "custom"
                    ]
                },
                "voiceKey": {
                    "type": "object",
                    "properties": {
                        "microphone": { "type": "string" },
                        "samplingRate": {
                            "type": "integer",
                            "minimum": 16000,
                            "unit": "Hz"
                        }
                    },
                    "required": [
                        "microphone",
                        "samplingRate"
                    ]
                },
                "rtPrecision": {
                    "type": "string",
                    "enum": [
                        "millisecond",
                        "microsecond"
                    ]
                }
            },
            "required": [
                "software",
                "responseDevice",
                "voiceKey",
                "rtPrecision"
            ]
        },
        "primaryOutputs": {
            "type": "object",
            "properties": {
                "reactionTime": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "trialId": { "type": "integer" },
                            "condition": {
                                "type": "string",
                                "enum": [
                                    "Congruent",
                                    "Incongruent",
                                    "Neutral"
                                ]
                            },
                            "rtMs": {
                                "type": "number",
                                "minimum": 0,
                                "unit": "milliseconds"
                            },
                            "accuracy": { "type": "boolean" },
                            "responseKey": { "type": "string" }
                        },
                        "required": [
                            "trialId",
                            "condition",
                            "rtMs",
                            "accuracy",
                            "responseKey"
                        ]
                    }
                },
                "interferenceScore": {
                    "type": "number",
                    "minimum": 0,
                    "unit": "milliseconds"
                },
                "errorRate": {
                    "type": "object",
                    "properties": {
                        "congruent": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 100,
                            "unit": "%"
                        },
                        "incongruent": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 100,
                            "unit": "%"
                        },
                        "neutral": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 100,
                            "unit": "%"
                        }
                    },
                    "required": [
                        "congruent",
                        "incongrent",
                        "neutral"
                    ]
                },
                "accuracyAdjustedRT": {
                    "type": "number",
                    "minimum": 0,
                    "unit": "milliseconds"
                }
            },
            "required": [
                "reactionTime",
                "interferenceScore",
                "errorRate"
            ]
        }
    },
    "required": [
        "taskType",
        "stimuli",
        "taskInstruction",
        "experimentalSettings",
        "instruments",
        "primaryOutputs",
        "expectedBehavior",
        "reliability",
        "cognitiveConstructs",
        "dataAnalysis",
        "validity",
        "neuroimaging",
        "neurocomputationalModeling",
        "clinicalApplications"
    ]
}
