{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "StroopTaskSchema",
    "type": "object",
    "properties": {
        "experimentMetadata": {
            "type": "object",
            "properties": {
                "experimentName": {
                    "type": "string",
                    },
                "experimentVariant": {
                    "type": "string",
                    "enum": [
                        "Classic",
                        "Emotional",
                        "Numerical",
                        "Spatial",
                        "Bilingual",
                        "Clinical"
                    ]
                },
                "experimentDate": {
                    "type": "string",
                    "format": "date",
                    },
                "institution": {
                    "type": "string"
                }
            },
            "required": [
                "experimentName",
                "experimentVariant"
            ]
        },
        "sampleCharacteristics": {
            "type": "object",
            "properties": {
                "sampleSize": {
                    "type": "integer",
                    "minimum": 1
                },
            "populationType": {
                    "type": "string",
                    "enum": [
                        "Adults",
                        "Children",
                        "Clinical"
                    ]
                },
                "clinicalDetails": {
                    "type": "string"
                },
                "visionStatus": {
                    "type": "string",
                    "enum": [
                        "Normal",
                        "CorrectedToNormal"
                    ]
                },
                "exclusionCriteria": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "ColorBlindness",
                            "NeurologicalDisorders",
                            "ChronicMedicalIllness"
                        ]
                    }
                }
            },
            "required": [
                "sampleSize",
                "ageRange",
                "populationType"
            ]
        },
        "stimuli": {
            "type": "object",
            "properties": {
                "colorSet": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "minItems": 3,
                    "maxItems": 6
                },
                "stimulusTypes": {
                    "type": "object",
                    "properties": {
                        "type": "array",
                        "items": {
                                "type": "string"
                        },
                        "enum": [
                            "congruent", 
                            "incongruent",
                            "neutral"
                        ], 
                        },
                        "colorPatches": {
                            "type": "boolean"
                        }
                    },
                    "required": [
                        "congruent",
                        "incongruent"
                    ]
                },
                "stimulusDuration": {
                    "type": "integer",
                    "unit": "milliseconds.",
                    "minimum": 500,
                    "maximum": 2000
                },
                "interTrialInterval": {
                    "type": "integer",
                    "unit": "milliseconds.",
                    "minimum": 500,
                    "maximum": 1500
                },
                "trialsPerCondition": {
                    "type": "integer",
                    "minimum": 20
                },
                "stimulusOrder": {
                    "type": "string",
                    "enum": [
                        "Randomized",
                        "Counterbalanced",
                        "Sequential"
                    ]
                }
            },
            "required": [
                "colorSet",
                "stimulusTypes",
                "stimulusDuration",
                "interTrialInterval",
                "trialsPerCondition",
                "stimulusOrder"
            ]
        },
        "taskInstructions": {
            "type": "object",
            "properties": {
                "responseMapping": {
                    "type": "string",
                    "enum": [
                        "InkColor",
                        "WordMeaning"
                    ]
                },
                "responseModality": {
                    "type": "string",
                    "enum": [
                        "Verbal",
                        "ManualKeypress"
                    ]
                },
                "keyMapping": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "practiceInstructions": {
                    "type": "string",
                }
            },
            "required": [
                "responseMapping",
                "responseModality"
            ]
        },
        "experimentalSettings": {
            "type": "object",
            "properties": {
                "software": {
                    "type": "string",
                },
                "hardware": {
                    "type": "object",
                    "properties": {
                        "responseDevice": {
                            "type": "string"
                        },
                        "display": {
                            "type": "object",
                            "properties": {
                                "luminance": {
                                    "type": "number",
                                },
                                "contrast": {
                                    "type": "number",
                                },
                                "resolution": {
                                    "type": "string",
                                }
                            }
                        }
                    },
                    "required": [
                        "responseDevice"
                    ]
                },
                "environment": {
                    "type": "object",
                    "properties": {
                        "lighting": {
                            "type": "string",
                            "enum": [
                                "Controlled",
                                "Ambient"
                            ]
                        },
                        "distractions": {
                            "type": "string",
                            "enum": [
                                "Minimal",
                                "Moderate"
                            ]
                        }
                    },
                    "required": [
                        "lighting"
                    ]
                }
            },
            "required": [
                "software",
                "hardware"
            ]
        },
        "practiceSessions": {
            "type": "object",
            "properties": {
                "conducted": {
                    "type": "boolean",
                },
                "durationDays": {
                    "type": "integer",
                    "minimum": 1
                },
                "trialsPerSession": {
                    "type": "integer",
                    "minimum": 1
                },
                "monitored": {
                    "type": "boolean",
                }
            }
        },
        "outputs": {
            "type": "object",
            "properties": {
                "reactionTime": {
                    "type": "object",
                    "unit": "milliseconds.",
                    "properties": {
                        "type": "number",
                        "enum":{
                            "congruent", 
                            "incongruent", 
                            "neutral",
                            "colorPatches"
                        },
                    },
                    "required": [
                        "congruent",
                        "incongruent"
                    ]
                },
                "errorRate": {
                    "type": "object",
                    "properties": {
                        "congruent": {
                            "type": "number",
                            "unit": "%",
                            "minimum": 0,
                            "maximum": 100
                        },
                        "incongruent": {
                            "type": "number",
                            "unit": "%",
                            "minimum": 0,
                            "maximum": 100
                        },
                        "neutral": {
                            "type": "number",
                            "unit": "%",
                            "minimum": 0,
                            "maximum": 100
                        },
                        "trialWiseErrors": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "trialNumber": {
                                        "type": "integer",
                                    },
                                    "condition": {
                                        "type": "string",
                                    },
                                    "error": {
                                        "type": "boolean",
                                    }
                                }
                            }
                        }
                    },
                    "required": [
                        "congruent",
                        "incongruent"
                    ]
                },
                "interferenceScore": {
                    "type": "number",
                    "unit": "milliseconds."
                },
                "practiceEffects": {
                    "type": "object",
                    "properties": {
                        "reactionTimeChange": {
                            "type": "number",
                            "unit": "ms"
                        },
                        "interferenceScoreChange": {
                            "type": "number",
                            "unit": "ms"
                        },
                        "statisticalSignificance": {
                            "type": "string",
                            "enum": [
                                "Significant",
                                "NotSignificant"
                            ]
                        }
                    }
                },
                "accuracyAdjustedRT": {
                    "type": "number",
                }
            },
            "required": [
                "reactionTime",
                "errorRate"
            ]
        },
        "dataAnalysis": {
            "type": "object",
            "properties": {
                "outlierExclusion": {
                    "type": "object",
                    "properties": {
                        "method": {
                            "type": "string",
                            "description": "Method used for outlier exclusion.",
                            "enum": [
                                "\u00b12 SD",
                                "FixedRange"
                            ]
                        },
                        "fixedRange": {
                            "type": "object",
                            "description": "Fixed range for outlier exclusion if method is 'FixedRange'.",
                            "properties": {
                                "type": "integer",
                                "unit": "ms", 
                                "enum": {"min", "max"}
                            },
                            "required": [
                                "min",
                                "max"
                            ]
                        }
                    },
                    "required": [
                        "method"
                    ]
                },
                "incorrectTrialHandling": {
                    "type": "string",
                    "enum": [
                        "Exclude",
                        "Include"
                    ]
                },
                "statisticalAnalysis": {
                    "type": "string",
                    "enum": [
                        "ANOVA",
                        "MixedEffectsModel",
                        "t-test"
                    ]
                },
                "statisticalSoftware": {
                    "type": "string",
                }
            },
            "required": [
                "outlierExclusion",
                "incorrectTrialHandling",
                "statisticalAnalysis"
            ]
        },
        "cognitiveConstructs": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "SelectiveAttention",
                    "ExecutiveControl",
                    "InhibitoryControl",
                    "ProcessingSpeed",
                    "ConflictMonitoring",
                    "Automaticity"
                ]
            }
        },
        "neuroimaging": {
            "type": "object",
            "properties": {
                "eeg": {
                    "type": "object",
                    "properties": {
                        "setup": {
                            "type": "object",
                            "properties": {
                                "channels": {
                                    "type": "integer",
                                    "minimum": 32,
                                    "maximum": 128
                                },
                                "samplingRate": {
                                    "type": "integer",
                                    "unit": "Hz",
                                    "minimum": 500,
                                    "maximum": 1000
                                },
                                "impedance": {
                                    "type": "number",
                                },
                                "reference": {
                                    "type": "string",
                                    "enum": [
                                        "LinkedMastoids",
                                        "AverageReference"
                                    ]
                                },
                                "eogChannels": {
                                    "type": "boolean",
                                }
                            },
                            "required": [
                                "channels",
                                "samplingRate",
                                "impedance",
                                "reference"
                            ]
                        },
                        "eventMarkers_eeg": {
                            "type": "object",
                            "properties": {
                                "stimulusOnset": {
                                    "type": "boolean",
                                },
                                "responseOnset": {
                                    "type": "boolean",
                                },
                                "accuracyCoding": {
                                    "type": "boolean",
                                }
                            },
                            "required": [
                                "stimulusOnset",
                                "responseOnset"
                            ]
                        },
                        "components_eeg": {
                            "type": "object",
                            "properties": {
                                "n200": {
                                    "type": "boolean",
                                },
                                "n450": {
                                    "type": "boolean",
                                },
                                "p300": {
                                    "type": "boolean",
                                },
                                "lpc": {
                                    "type": "boolean"
                                }
                            }
                        },
                        "expectedPatterns_EEG": {
                            "type": "object",
                            "properties": {
                                "n450Amplitude": {
                                    "type": "string",
                                    "enum": [
                                        "Increased",
                                        "Decreased"
                                    ]
                                },
                                "frontoCentralActivation": {
                                    "type": "string",
                                    "enum": [
                                        "Increased",
                                        "Decreased"
                                    ]
                                },
                                "thetaPower": {
                                    "type": "string",
                                    "enum": [
                                        "Increased",
                                        "Decreased"
                                    ]
                                }
                            }
                        }
                    },
                    "required": [
                        "setup",
                        "eventMarkers"
                    ]
                },
                "fmri": {
                    "type": "object",
                    "properties": {
                        "scannerParameters": {
                            "type": "object",
                            "properties": {
                                "fieldStrength": {
                                    "type": "number",
                                    "unit": "Tesla."
                                },
                                "tr": {
                                    "type": "number",
                                    "unit": "milliseconds.",
                                    "minimum": 2000,
                                    "maximum": 2500
                                },
                                "te": {
                                    "type": "number",
                                    "unit": "milliseconds."
                                },
                                "voxelSize": {
                                    "type": "string",
                                    "unit": "mm."
                                },
                                "brain_coverage": {
                                    "type": "string",
                                }
                            },
                            "required": [
                                "fieldStrength",
                                "tr",
                                "te",
                                "voxelSize",
                                "brain_coverage"
                            ]
                        },
                        "design": {
                            "type": "string",
                            "enum": [
                                "EventRelated",
                                "BlockDesign"
                            ]
                        },
                        "keyRegions": {
                            "type": "object",
                            "properties": {
                                "acc": {
                                    "type": "boolean",
                                },
                                "dlpfc": {
                                    "type": "boolean",
                                },
                                "ifg": {
                                    "type": "boolean"
                                },
                                "parietalCortex": {
                                    "type": "boolean"
                                },
                                "basalGanglia": {
                                    "type": "boolean"
                                }
                            }
                        },
                        "expectedContrast": {
                            "type": "string",
                            "enum": [
                                "Incongruent > Congruent"
                            ]
                        },
                        "connectivityAnalysis": {
                            "type": "object",
                            "properties": {
                                "functionalConnectivity": {
                                    "type": "boolean",
                                },
                                "frontoParietalNetwork": {
                                    "type": "boolean",
                                },
                                "eegCoherence": {
                                    "type": "boolean",
                                },
                                "dcm": {
                                    "type": "boolean"
                                }
                            }
                        }
                    },
                    "required": [
                        "scannerParameters",
                        "design"
                    ]
                },
                "behavioralNeuralCoupling": {
                    "type": "object",
                    "properties": {
                        "interferenceScoreAccCorrelation": {
                            "type": "boolean",
                        },
                        "n450RtSlowingCorrelation": {
                            "type": "boolean",
                        },
                        "thetaPowerErrorCorrelation": {
                            "type": "boolean",
                        },
                        "grattonEffect": {
                            "type": "boolean",
                        }
                    }
                }
            }
        },
        "neurocomputationalModeling": {
            "type": "object",
            "properties": {
                "modelType": {
                    "type": "string",
                    "enum": [
                        "DriftDiffusion",
                        "ConflictMonitoring"
                    ]
                },
                "keyVariables": {
                    "type": "object",
                    "properties": {
                        "driftRate": {
                            "type": "boolean",
                        },
                        "decisionThreshold": {
                            "type": "boolean",
                        },
                        "conflictSignalStrength": {
                            "type": "boolean",
                        },
                        "controlGainModulation": {
                            "type": "boolean",
                        }
                    }
                }
            }
        },
        "clinicalApplications": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "ADHD",
                    "Depression",
                    "Schizophrenia",
                    "FrontalLobeLesions",
                    "Aging"
                ]
            }
        },
        "reliability": {
            "type": "object",
            "properties": {
                "testRetestReliability": {
                    "type": "string",
                    "enum": [
                        "Low",
                        "Moderate",
                        "High"
                    ]
                },
                "groupLevelEffects": {
                    "type": "string",
                    "enum": [
                        "Weak",
                        "Moderate",
                        "Strong"
                    ]
                },
                "individualDifferenceReliability": {
                    "type": "string",
                }
            },
            "required": [
                "testRetestReliability",
                "groupLevelEffects"
            ]
        },
        "validity": {
            "type": "object",
            "properties": {
                "constructValidity": {
                    "type": "string",
                    "enum": [
                        "Weak",
                        "Moderate",
                        "Strong"
                    ]
                },
                "sensitivity": {
                    "type": "string",
                    "enum": [
                        "Low",
                        "Moderate",
                        "High"
                    ]
                },
                "influencingFactors": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "ReadingProficiency",
                            "LanguageFamiliarity",
                            "Age",
                            "CulturalBackground",
                            "PracticeEffects"
                        ]
                    }
                }
            },
            "required": [
                "constructValidity",
                "sensitivity"
            ]
        }
    },
    "required": [
        "experimentMetadata",
        "sampleCharacteristics",
        "stimuli",
        "taskInstructions",
        "experimentalSettings",
        "outputs",
        "dataAnalysis",
        "cognitiveConstructs",
        "reliability",
        "validity"
    ]
}
