{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://example.com/stroop-task-process-refined.json",
    "title": "Refined Stroop Task Process Schema",
    "type": "object",
    "properties": {
        "metadata": {
            "type": "object",
            "properties": {
                "experiment_id": {
                    "type": "string"
                },
                "date": {
                    "type": "string",
                    "format": "date",
                },
                "study_type": {
                    "type": "string",
                    "enum": [
                        "basic",
                        "clinical",
                        "neuroimaging",
                        "neurocomputational"
                    ],
                },
                "participant_group": {
                    "type": "object",
                    "properties": {
                        "age_group": {
                            "type": "string",
                            "enum": [
                                "children",
                                "adults",
                                "elderly"
                            ],
                        },
                        "control_status": {
                            "type": "string",
                            "enum": [
                                "healthy_controls",
                                "clinical"
                            ],
                        }
                    },
                    "required": [
                        "age_group",
                        "control_status"
                    ]
                },
                "sample_size": {
                    "type": "integer",
                    "minimum": 20,
                },
                "practice_session": {
                    "type": "object",
                    "properties": {
                        "duration_days": {
                            "type": "integer",
                            "minimum": 0,
                        },
                        "frequency": {
                            "type": "string",
                          },
                        "monitored": {
                            "type": "boolean",
                            }
                    }
                }
            },
            "required": [
                "experiment_id",
                "date",
                "study_type",
                "participant_group",
                "sample_size"
            ]
        },
        "task_definition": {
            "type": "object",
            "properties": {
                "task_variant": {
                    "type": "string",
                    "enum": [
                        "standard",
                        "emotional",
                        "numerical",
                        "spatial",
                        "bilingual",
                        "clinical"
                    ],
                },
                "response_instruction": {
                    "type": "string",
                    "enum": [
                        "name_color",
                        "read_word",
                        "reverse_stroop"
                    ],
                },
                "response_modality": {
                    "type": "string",
                    "enum": [
                        "verbal",
                        "manual_keypress"
                    ],
                    },
                "stimulus_properties": {
                    "type": "object",
                    "properties": {
                        "stimulus_set": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "condition": {
                                        "type": "string",
                                        "enum": [
                                            "congruent",
                                            "neutral",
                                            "incongruent"
                                        ],
                                        },
                                    "stimulus_type": {
                                        "type": "string",
                                        "enum": [
                                            "color_patches",
                                            "color_words",
                                            "symbols"
                                        ],
                                       },
                                    "items": {
                                        "type": "array",
                                        "items": {
                                            "type": "object",
                                            "properties": {
                                                "word": {
                                                    "type": "string",
                                                    },
                                                "ink_color": {
                                                    "type": "string",
                                                    "enum": [
                                                        "red",
                                                        "blue",
                                                        "green",
                                                        "yellow",
                                                        "purple",
                                                        "orange"
                                                    ],
                                                    },
                                                "color_name": {
                                                    "type": "string",
                                                    }
                                            },
                                            "required": [
                                                "word",
                                                "ink_color"
                                            ]
                                        }
                                    }
                                },
                                "required": [
                                    "condition",
                                    "stimulus_type",
                                    "items"
                                ]
                            }
                        },
                        "color_set": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "red",
                                    "blue",
                                    "green",
                                    "yellow",
                                    "purple",
                                    "orange"
                                ],
                                },
                            "minItems": 3,
                            "maxItems": 6,
                        }
                    },
                    "required": [
                        "stimulus_set",
                        "color_set"
                    ]
                },
                "practice_effect": {
                    "type": "object",
                    "properties": {
                        "pre_practice_response_times": {
                            "type": "object",
                            "properties": {
                                "congruent": {
                                    "type": "number",
                                    "unit": "milliseconds"
                                },
                                "incongruent": {
                                    "type": "number",
                                    "unit": "milliseconds"
                                }
                            },
                            "required": [
                                "congruent",
                                "incongruent"
                            ]
                        },
                        "post_practice_response_times": {
                            "type": "object",
                            "properties": {
                                "type": "number",
                                "unit": "milliseconds",
                                "enum": [
                                    "congruent",
                                    "incongruent"
                                ],
                            },
                            "required": [
                                "congruent",
                                "incongruent"
                            ]
                        },
                        "significant_change": {
                            "type": "boolean",
                        }
                    }
                }
            },
            "required": [
                "task_variant",
                "response_instruction",
                "response_modality",
                "stimulus_properties"
            ]
        },
        "experimental_settings": {
            "type": "object",
            "properties": {
                "stimulus_duration": {
                    "type": "number",
                    "minimum": 500,
                    "unit": "ms",
                    "default": "1000"
                },
                "inter_trial_interval": {
                    "type": "number",
                    "minimum": 500,
                    "unit": "ms",
                    "default": "1000"
                },
                "trials_per_condition": {
                    "type": "integer",
                    "minimum": 20,
                },
                "ordering_strategy": {
                    "type": "string",
                    "enum": [
                        "randomized",
                        "counterbalanced"
                    ],
                },
                "environment": {
                    "type": "object",
                    "properties": {
                        "lighting": {
                            "type": "string",
                        },
                        "distractions": {
                            "type": "boolean",
                        },
                        "background": {
                            "type": "string",
                        }
                    },
                }
            },
            "required": [
                "stimulus_duration",
                "inter_trial_interval",
                "trials_per_condition",
                "ordering_strategy"
            ]
        },
        "instruments": {
            "type": "object",
            "properties": {
                "software": {
                    "type": "string",
                    "enum": [
                        "PsychoPy",
                        "E-Prime",
                        "MATLAB Psychtoolbox",
                        "Custom"
                    ],
                },
                "response_device": {
                    "type": "string",
                    "enum": [
                        "keyboard",
                        "response_pad",
                        "voice_key",
                        "touchscreen"
                    ],
                },
                "display": {
                    "type": "object",
                    "properties": {
                        "luminance": {
                            "type": "number",
                            "minimum": 0,
                            "unit": "candela per square meter (cd/m\u00b2)."
                        },
                        "contrast": {
                            "type": "number",
                            "minimum": 0,
                        },
                        "screen_size": {
                            "type": "number",
                            "minimum": 19,
                            "unit": "inches."
                        }
                    },
                    },
                "reaction_time_precision": {
                    "type": "number",
                    "minimum": 0.001,
                    "unit": "Millisecond resolution"
                }
            },
            "required": [
                "software",
                "response_device",
                "display",
                "reaction_time_precision"
            ]
        },
        "outputs": {
            "type": "object",
            "properties": {
                "reaction_times": {
                    "type": "object",
                    "properties": {
                        "type": "array",
                            "items": {
                                "type": "number",
                                "minimum": 200,
                                "unit": "milliseconds (ms)."
                            },
                        "enum": ["congruent", "incongruent", "neutral"]
                    },
                },
                "error_rates": {
                    "type": "object",
                    "properties": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1,
                        "enum": ["congruent", "incongruent", "neutral"]
                    },
                },
                "interference_score": {
                    "type": "number",
                },
                "accuracy_adjusted_rt": {
                    "type": "boolean",
                },
                "practice_effects": {
                    "type": "object",
                    "properties": {
                        "type": "number",
                        "enum": ["pre_practice_interference", "post_practice_interference"]
                    }
                }
            },
            "required": [
                "reaction_times",
                "error_rates",
                "interference_score"
            ]
        },
        "neuroimaging": {
            "type": "object",
            "properties": {
                "implementation": {
                    "type": "string",
                    "enum": [
                        "EEG",
                        "fMRI"
                    ],
                },
                "setup": {
                    "type": "object",
                    "properties": {
                        "modality": {
                            "type": "object",
                            "properties": {
                                "EEG": {
                                    "type": "object",
                                    "properties": {
                                        "channels": {
                                            "type": "integer",
                                            "minimum": 32,
                                        },
                                        "sampling_rate": {
                                            "type": "number",
                                            "minimum": 500,
                                            "unit": "Hertz (Hz)."
                                        },
                                        "impedance": {
                                            "type": "number",
                                            "minimum": 0,
                                            "unit": "kilo-ohms"
                                        },
                                        "reference": {
                                            "type": "string",
                                            "enum": [
                                                "linked_mastoids",
                                                "average_reference"
                                            ],
                                        }
                                    },
                                    "required": [
                                        "channels",
                                        "sampling_rate",
                                        "impedance",
                                        "reference"
                                    ]
                                },
                                "fMRI": {
                                    "type": "object",
                                    "properties": {
                                        "scanner": {
                                            "type": "string"
                                        },
                                        "TR": {
                                            "type": "number",
                                            "minimum": 2000,
                                            "unit": "milliseconds (ms)."
                                        },
                                        "TE": {
                                            "type": "number",
                                            "minimum": 20,
                                            "unit": "milliseconds (ms)."
                                        },
                                        "voxel_size": {
                                            "type": "object",
                                            "properties": {
                                                "unit": "milliseconds (ms)."
                                                "type": "number",
                                                "minimum": 1,
                                                "enum": ["x", "y", "z"],
                                            },
                                            "required": [
                                                "x",
                                                "y",
                                                "z"
                                            ],
                                        }
                                    },
                                    "required": [
                                        "scanner",
                                        "TR",
                                        "TE",
                                        "voxel_size"
                                    ]
                                }
                            },
                            "oneOf": [
                                {
                                    "required": [
                                        "EEG"
                                    ]
                                },
                                {
                                    "required": [
                                        "fMRI"
                                    ]
                                }
                            ]
                        },
                        "event_markers": {
                            "type": "object",
                            "properties": {
                                "EEG": {
                                    "type": "array",
                                    "items": {
                                        "type": "string",
                                        "enum": [
                                            "stimulus_onset",
                                            "response_onset",
                                            "accuracy"
                                        ],
                                        },
                                },
                                "fMRI": {
                                    "type": "array",
                                    "items": {
                                        "type": "string",
                                        "enum": [
                                            "stimulus_onset",
                                            "response_onset",
                                            "accuracy"
                                        ],
                                      },
                                    }
                            },
                            "oneOf": [
                                {
                                    "required": [
                                        "EEG"
                                    ]
                                },
                                {
                                    "required": [
                                        "fMRI"
                                    ]
                                }
                            ]
                        }
                    },
                    "required": [
                        "implementation",
                        "setup"
                    ]
                },
                "key_components": {
                    "type": "object",
                    "properties": {
                        "EEG": {
                            "type": "object",
                            "properties": {
                                "components": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "component": {
                                                "type": "string",
                                                "enum": [
                                                    "N200",
                                                    "N450",
                                                    "P300",
                                                    "LPC"
                                                ],
                                                },
                                            "latency": {
                                                "type": "number",
                                                "unit": "milliseconds (ms)."
                                            },
                                            "interpretation": {
                                                "type": "string",
                                                }
                                        },
                                        "required": [
                                            "component",
                                            "latency",
                                            "interpretation"
                                        ]
                                    },
                                  }
                            },
                            "required": [
                                "components"
                            ]
                        },
                        "fMRI": {
                            "type": "object",
                            "properties": {
                                "regions": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "region": {
                                                "type": "string",
                                                "enum": [
                                                    "anterior_cingulate_cortex",
                                                    "dorsolateral_prefrontal_cortex",
                                                    "inferior_frontal_gyrus",
                                                    "parietal_cortex",
                                                    "basal_ganglia"
                                                ],
                                            },
                                            "role": {
                                                "type": "string",
                                            }
                                        },
                                        "required": [
                                            "region",
                                            "role"
                                        ]
                                    },
                                }
                            },
                            "required": [
                                "regions"
                            ]
                        }
                    },
                    "oneOf": [
                        {
                            "required": [
                                "EEG"
                            ]
                        },
                        {
                            "required": [
                                "fMRI"
                            ]
                        }
                    ]
                }
            },
            "required": [
                "implementation",
                "setup",
                "key_components"
            ]
        },
        "neurocomputational": {
            "type": "object",
            "properties": {
                "model_type": {
                    "type": "string",
                    "enum": [
                        "parallel_processing",
                        "competitive_inhibition",
                        "drift_diffusion",
                        "conflict_monitoring"
                    ],
                },
                "variables": {
                    "type": "object",
                    "properties": {
                        "type": "number",
                        "enum": ["drift_rate", "decision_threshold", "conflict_signal_strength", "control_gain_modulation"]
                    },
                  }
            },
            "required": [
                "model_type"
            ]
        },
        "clinical_applications": {
            "type": "object",
            "properties": {
                "condition": {
                    "type": "string",
                    "enum": [
                        "ADHD",
                        "depression",
                        "schizophrenia",
                        "frontal_lobe_damage",
                        "aging",
                        "clinical"
                    ],
                   },
                "expected_pattern": {
                    "type": "string",
                    },
                "diagnostic_criteria": {
                    "type": "string",
                    }
            },
            "required": [
                "condition"
            ]
        },
        "data_analysis": {
            "type": "object",
            "properties": {
                "outlier_exclusion": {
                    "type": "object",
                    "properties": {
                        "RT_outliers": {
                            "type": "object",
                            "properties": {
                                "lower_bound": {
                                    "type": "number",
                                    },
                                "upper_bound": {
                                    "type": "number",
                                    },
                                "SD_threshold": {
                                    "type": "number",
                                   }
                            },
                            "required": [
                                "lower_bound",
                                "upper_bound",
                                "SD_threshold"
                            ]
                        },
                        "error_exclusions": {
                            "type": "boolean",
                            }
                    },
                    "required": [
                        "RT_outliers",
                        "error_exclusions"
                    ]
                },
                "analysis_method": {
                    "type": "string",
                    "enum": [
                        "within_subject_ANOVA",
                        "mixed_effects_modeling"
                    ],
                    },
                "practice_analysis": {
                    "type": "object",
                    "properties": {
                        "pre_practice_analysis": {
                            "type": "string",
                        },
                        "post_practice_analysis": {
                            "type": "string",
                           }
                    }
                }
            },
            "required": [
                "outlier_exclusion",
                "analysis_method"
            ]
        }
    },
    "required": [
        "metadata",
        "task_definition",
        "experimental_settings",
        "instruments",
        "outputs",
        "neuroimaging",
        "data_analysis"
    ]
}
