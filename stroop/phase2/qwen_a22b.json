{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Stroop Task Process Schema",
    
    "type": "object",
    "required": [
        "taskVariant",
        "sampleCharacteristics",
        "stimuli",
        "taskInstructions",
        "experimentalSettings",
        "instruments",
        "outputs",
        "cognitiveConstructs"
    ],
    "properties": {
        "taskVariant": {
            "type": "string",
            
            "enum": [
                "Standard",
                "Emotional Stroop",
                "Numerical Stroop",
                "Spatial Stroop",
                "Bilingual Stroop",
                "Clinical Adaptation"
            ]
        },
        "sampleCharacteristics": {
            "type": "object",
           
            "properties": {
                "ageRange": {
                    "type": "array",
                    
                    "items": {
                        "type": "integer",
                        "minimum": 0
                    },
                    "minItems": 2,
                    "maxItems": 2
                },
                "population": {
                    "type": "string",
                    
                },
                "sampleSize": {
                    "type": "integer",
                    
                    "minimum": 1
                },
                "inclusionCriteria": {
                    "type": "array",
                    
                    "items": {
                        "type": "string"
                    }
                },
                "exclusionCriteria": {
                    "type": "array",
                    
                    "items": {
                        "type": "string"
                    }
                },
                "practiceExperience": {
                    "type": "object",
                    
                    "properties": {
                        "priorStroopExperience": {
                            "type": "boolean",
                            
                        },
                        "practiceSessionCount": {
                            "type": "integer",
                           
                            "minimum": 0
                        },
                        "practiceDuration": {
                            "type": "integer",
                           
                            "minimum": 0,
                            "unit": "days"
                        }
                    }
                }
            },
            "required": [
                "ageRange",
                "sampleSize"
            ]
        },
        "stimuli": {
            "type": "object",
            
            "properties": {
                "presentationFormat": {
                    "type": "string",
                   
                    "enum": [
                        "Card-based",
                        "Trial-based digital"
                    ]
                },
                "cardConfiguration": {
                    "type": "object",
                    
                    "properties": {
                        "cardCount": {
                            "type": "integer",
                            
                            "minimum": 1
                        },
                        "cardTypes": {
                            "type": "array",
                           
                            "items": {
                                "type": "string",
                                "enum": [
                                    "Color patches",
                                    "Congruent words",
                                    "Incongruent words"
                                ]
                            }
                        }
                    }
                },
                "type": "array",
                "items": {
                        "type": "string"
                    },
                "enum": ["congruent", "incongruent", "neutral"]
                },
                "colorSet": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "minItems": 3,
                    "maxItems": 6
                },
                "wordSet": {
                    "type": "array",
                
                    "items": {
                        "type": "string"
                    }
                },
                "stimulusDensity": {
                    "type": "integer",
                    
                    "minimum": 1
                }
            },
            "required": [
                "congruent",
                "incongruent",
                "colorSet"
            ]
        },
        "taskInstructions": {
            "type": "object",
            
            "properties": {
                "instructionSets": {
                    "type": "array",
                    
                    "items": {
                        "type": "object",
                        "properties": {
                            "phase": {
                                "type": "string",
                                
                            },
                            "responseMapping": {
                                "type": "string",
                            
                                "enum": [
                                    "Name ink color (ignore word)",
                                    "Read word (ignore ink color)"
                                ]
                            }
                        },
                        "required": [
                            "phase",
                            "responseMapping"
                        ]
                    }
                },
                "responseModality": {
                    "type": "string",
                    
                    "enum": [
                        "Verbal (voice key)",
                        "Manual keypress",
                        "Stopwatch timing"
                    ]
                },
                "timingMethod": {
                    "type": "string",
                    
                    "enum": [
                        "Digital recording",
                        "Stopwatch"
                    ]
                },
                "timingUnit": {
                    "type": "string",
                    
                    "enum": [
                        "ms",
                        "seconds",
                        "minutes"
                    ],
                    "default": "ms"
                }
            },
            "required": [
                "instructionSets",
                "responseModality"
            ]
        },
        "experimentalSettings": {
            "type": "object",
            "properties": {
                "stimulusDuration": {
                    "type": "number",
                    
                    "unit": "ms",
                    "minimum": 0,
                    "maximum": 2000,
                    "default": 0
                },
                "interTrialInterval": {
                    "type": "number",
                    
                    "unit": "ms",
                    "minimum": 100,
                    "maximum": 1500,
                    "default": 1000
                },
                "trialsPerCondition": {
                    "type": "integer",
                    
                    "minimum": 10,
                    "default": 40
                },
                "randomization": {
                    "type": "string",
                    
                    "enum": [
                        "Randomized",
                        "Counterbalanced",
                        "Blocked"
                    ],
                    "default": "Randomized"
                },
                "environment": {
                    "type": "string",
                    
                },
                "practiceProtocol": {
                    "type": "object",
                    
                    "properties": {
                        "hasPractice": {
                            "type": "boolean",
                           
                        },
                        "practiceDuration": {
                            "type": "integer",
                           
                            "unit": "days",
                            "minimum": 0
                        },
                        "practiceContent": {
                            "type": "string",
                            
                        },
                        "practiceMonitoring": {
                            "type": "boolean",
                          
                        }
                    }
                }
            },
            "required": [
                "trialsPerCondition"
            ]
        },
        "instruments": {
            "type": "object",
            
            "properties": {
                "software": {
                    "type": "string",
                    
                },
                "responseDevice": {
                    "type": "string",
                    
                },
                "voiceKey": {
                    "type": "boolean",
                    
                    "default": false
                },
                "displayCalibration": {
                    "type": "string",
                   
                },
                "timingPrecision": {
                    "type": "string",
                }
            },
            "required": [
                "software"
            ]
        },
        "outputs": {
            "type": "object",
            "properties": {
                "reactionTime": {
                    "type": "object",
                    
                    "properties": {
                        "unit": {
                            "type": "string",
                            "unit": "ms"
                        },
                        "type": "number",
                        "enum": ["congruent", "incongruent", "neutral"]
                    
                    },
                    "required": [
                        "congruent",
                        "incongruent"
                    ]
                },
                "errorRate": {
                    "type": "object",
                    
                    "properties": {
                        "unit": {
                            "type": "string",
                            "unit": "%"
                           
                        },
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100,
                        "enum": ["congruent", "incongruent", "neutral"]
                    },
                    "required": [
                        "congruent",
                        "incongruent"
                    ]
                },
                "interferenceScore": {
                    "type": "number",
                    
                    "unit": "ms"
                },
                "accuracyAdjustedRT": {
                    "type": "number",
                  
                    "unit": "ms"
                },
                "practiceEffect": {
                    "type": "object",
                   
                    "properties": {
                        "rtChange": {
                            "type": "number",
                            
                            "unit": "ms"
                        },
                        "errorRateChange": {
                            "type": "number",
                            
                            "unit": "%"
                        },
                        "interferenceScoreChange": {
                            "type": "number",
                            "unit": "ms"
                        }
                    }
                }
            },
            "required": [
                "reactionTime",
                "errorRate",
                "interferenceScore"
            ]
        },
        "cognitiveConstructs": {
            "type": "array",
            
            "items": {
                "type": "string",
                "enum": [
                    "Selective attention",
                    "Executive control",
                    "Inhibitory control",
                    "Processing speed",
                    "Conflict monitoring",
                    "Cognitive flexibility",
                    "Working memory"
                ]
            },
            "minItems": 2
        },
        "expectedBehavioralPattern": {
            "type": "string",
            
            "default": "Incongruent trials produce significantly longer RTs and higher error rates than congruent trials"
        },
        "reliabilityCharacteristics": {
            "type": "string",
           
            "default": "Moderate-to-high reliability; improves with increased trial count (>60 trials/condition)"
        },
        "dataAnalysisNorms": {
            "type": "object",
            
            "properties": {
                "outlierExclusion": {
                    "type": "string",
                    
                    "default": "Trials <200ms or >3000ms excluded; \u00b12.5 SD within subject"
                },
                "incorrectTrialRemoval": {
                    "type": "boolean",
                    
                    "default": true
                },
                "errorHandlingProtocol": {
                    "type": "string",
                    
                },
                "statisticalMethods": {
                    "type": "array",
                    
                    "items": {
                        "type": "string",
                        "enum": [
                            "Within-subject ANOVA",
                            "Mixed-effects modeling",
                            "t-test (congruent vs incongruent)"
                        ]
                    },
                    "default": [
                        "Within-subject ANOVA"
                    ]
                }
            }
        },
        "validityNotes": {
            "type": "object",
            
            "properties": {
                "constructValidity": {
                    "type": "string",
                    
                    "default": "Strong validity for interference control and inhibitory processes"
                },
                "sensitivity": {
                    "type": "string",
                   
                    "default": "Sensitive to frontal lobe dysfunction and executive control deficits"
                },
                "influencingFactors": {
                    "type": "array",
                    
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "Reading proficiency",
                        "Language familiarity",
                        "Color vision acuity",
                        "Practice effects"
                    ]
                }
            }
        },
        "neuroimaging": {
            "type": "object",
            
            "properties": {
                "eeg": {
                    "type": "object",
                    
                    "properties": {
                        "channels": {
                            "type": "integer",
                            
                            "minimum": 16,
                            "maximum": 256
                        },
                        "samplingRate": {
                            "type": "number",
                           
                            "unit": "Hz",
                            "minimum": 250
                        },
                        "keyComponents": {
                            "type": "array",
                            
                            "items": {
                                "type": "object",
                                "properties": {
                                    "type": "string",
                                    "enum": ["component", "latencyRange", "interpretation"]
                                    
                                },
                                "required": [
                                    "component",
                                    "latencyRange"
                                ]
                            }
                        }
                    }
                },
                "fmri": {
                    "type": "object",
                    
                    "properties": {
                        "fieldStrength": {
                            "type": "number",
                            
                            "unit": "T",
                            "enum": [
                                1.5,
                                3,
                                7
                            ],
                            "default": 3
                        },
                        "tr": {
                            "type": "number",
                            
                            "unit": "ms"
                        },
                        "keyRegions": {
                            "type": "array",
                            
                            "items": {
                                "type": "object",
                                "properties": {
                                    "type": "string",
                                    "enum": ["region", "functionalRole"]
                                    
                                },
                                "required": [
                                    "region",
                                    "functionalRole"
                                ]
                            }
                        }
                    }
                },
                "behavioralNeuralCoupling": {
                    "type": "array",
                    
                    "items": {
                        "type": "string"
                    }
                }
            }
        }
    }
}
