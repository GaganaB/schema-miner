{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Stroop Task Process Schema",
    "type": "object",
    "properties": {
        "task_details": {
            "type": "object",
            "properties": {
                "task_variant": {
                    "type": "string",
                    "description": "The specific variant of the Stroop task (e.g., Emotional Stroop, Numerical Stroop, Spatial Stroop, Bilingual Stroop, Standard).",
                    "enum": [
                        "Emotional Stroop",
                        "Numerical Stroop",
                        "Spatial Stroop",
                        "Bilingual Stroop",
                        "Color-Word Stroop"
                    ]
                },
                "clinical_adaptation": {
                    "type": "boolean",
                    "default": false
                },
                "population": {
                    "type": "string",
                    "enum": [
                        "Adults",
                        "Children",
                        "Clinical Population"
                    ]
                },
                "sample_size": {
                    "type": "integer",
                    "minimum": 20,
                    "maximum": 200
                }
            }
        },
        "stimuli": {
            "type": "object",
            "properties": {
                "color_set": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "minItems": 3,
                    "maxItems": 6
                },
                "stimulus_types": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "Congruent",
                            "Incongruent",
                            "Neutral"
                        ]
                    }
                },
                "stimulus_presentation_order": {
                    "type": "string",
                    "enum": [
                        "Randomized",
                        "Counterbalanced"
                    ]
                }
            }
        },
        "task_instructions": {
            "type": "object",
            "properties": {
                "response_type": {
                    "type": "string",
                    "enum": [
                        "Ink Color",
                        "Word Reading"
                    ]
                },
                "response_modality": {
                    "type": "string",
                    "enum": [
                        "Verbal",
                        "Manual"
                    ]
                }
            }
        },
        "experimental_settings": {
            "type": "object",
            "properties": {
                "stimulus_duration": {
                    "type": "integer",
                    "unit": "milliseconds.",
                    "minimum": 500,
                    "maximum": 2000
                },
                "inter_trial_interval": {
                    "type": "integer",
                    "unit": "milliseconds.",
                    "minimum": 500,
                    "maximum": 1500
                },
                "trials_per_condition": {
                    "type": "integer",
                    "minimum": 20,
                    "maximum": 100
                },
                "practice_trials": {
                    "type": "integer",
                    "minimum": 0
                }
            }
        },
        "instruments_apparatus": {
            "type": "object",
            "properties": {
                "software": {
                    "type": "string"
                },
                "reaction_time_precision": {
                    "type": "string",
                    "default": "millisecond"
                }
            }
        },
        "outputs": {
            "type": "object",
            "properties": {
                "reaction_time": {
                    "type": "number",
                    "unit": "milliseconds (ms)."
                },
                "error_rate": {
                    "type": "number",
                    "unit": "percentage (%)",
                    "minimum": 0,
                    "maximum": 100
                },
                "interference_score": {
                    "type": "number"
                }
            }
        },
        "neuroimaging": {
            "type": "object",
            "properties": {
                "modality": {
                    "type": "string",
                    "enum": ["EEG", "fMRI"]
                },
                "eeg_parameters": {
                    "type": "object",
                    "properties": {
                        "channel_count": {
                            "type": "integer",
                            "minimum": 32,
                            "maximum": 128
                        },
                        "sampling_rate": {
                            "type": "integer",
                            "minimum": 500,
                            "unit": "Hz"
                        }
                    },
                    "required": ["channel_count", "sampling_rate"]
                },
            "fmri_parameters": {
                "type": "object",
                "properties": {
                    "tr": {
                        "type": "number",
                        "minimum": 2000,
                        "maximum": 2500,
                        "unit": "milliseconds"
                    },
                    "voxel_size": {
                        "type": "string",
                        "unit": "mm",
                        "enum": ["x", "y", "z"]
                    }
                },
        "required": ["tr", "voxel_size"]
      }
    },
    "required": ["modality"],
    "allOf": [
      {
        "if": {
          "properties": {
            "modality": { "const": "EEG" }
          }
        },
        "then": {
          "required": ["eeg_parameters"],
          "not": {
            "required": ["fmri_parameters"]
          }
        }
      },
      {
        "if": {
          "properties": {
            "modality": { "const": "fMRI" }
          }
        },
        "then": {
          "required": ["fmri_parameters"],
          "not": {
            "required": ["eeg_parameters"]
          }
        }
      }
    ]
  }
}
    "required": [
        "task_details",
        "stimuli",
        "task_instructions",
        "experimental_settings",
        "outputs"
    ]
}
