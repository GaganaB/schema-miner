{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Stroop Task Process Schema",
  "type": "object",
  "required": ["experiment", "apparatus", "outputs"],
  "properties": {
    "experiment": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "enum": ["Standard", "Emotional", "Bilingual"],
          "default": "Standard"
        },
        "purpose": {
          "type": "string",
          "enum": [
            "Selective attention", "Executive control", "Inhibitory control",
            "Processing speed", "Conflict monitoring", "Emotional processing",
            "Response inhibition", "Language processing"
          ],
          "default": "Selective attention"
        },
        "population": {
          "type": "object",
          "properties": {
            "size": { "type": "integer", "minimum": 20, "maximum": 200, "default": 30 },
            "age_range": {
              "type": "object",
              "properties": {
                "min": { "type": "number", "minimum": 0, "default": 18 },
                "max": { "type": "number", "minimum": 0, "default": 65 }
              }
            },
            "clinical": { "type": "boolean", "default": false },
            "clinical_populations": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["ADHD", "Depression", "Schizophrenia", "Frontal lobe lesions", "Aging"]
              },
              "default": []
            }
          }
        },
        "stimuli": {
          "type": "object",
          "properties": {
            "color_set": {
              "type": "array",
              "items": { "type": "string", "enum": ["red", "blue", "green", "yellow", "black", "white"] },
              "minItems": 3,
              "maxItems": 6,
              "default": ["red", "blue", "green", "yellow"]
            },
            "conditions": {
              "type": "object",
              "properties": {
                "congruent":   { "type": "boolean", "default": true },
                "incongruent": { "type": "boolean", "default": true },
                "neutral":     { "type": "boolean", "default": true },
                "emotional":   { "type": "boolean", "default": false }
              }
            },
            "trial_count": {
              "type": "object",
              "properties": {
                "congruent":   { "type": "integer", "minimum": 20, "maximum": 100, "default": 20 },
                "incongruent": { "type": "integer", "minimum": 20, "maximum": 100, "default": 20 },
                "neutral":     { "type": "integer", "minimum": 20, "maximum": 100, "default": 20 },
                "emotional":   { "type": "integer", "minimum": 0,  "maximum": 100, "default": 0 }
              }
            }
          }
        },
        "task_instruction": {
          "type": "object",
          "properties": {
            "response_mode": { "type": "string", "enum": ["Verbal", "Manual"] },
            "response_mapping": {
              "type": "object",
              "properties": {
                "standard": { "type": "boolean", "default": true },
                "reverse":  { "type": "boolean", "default": false }
              }
            },
            "practice_sessions": {
              "type": "object",
              "properties": {
                "duration":               { "type": "integer", "minimum": 1, "default": 6 },
                "effect_on_interference": { "type": "boolean", "default": false }
              }
            }
          }
        },
        "timing": {
          "type": "object",
          "properties": {
            "stimulus_duration":    { "type": "number", "minimum": 500, "maximum": 2000, "default": 1000 },
            "inter_trial_interval": { "type": "number", "minimum": 500, "maximum": 1500, "default": 1000 },
            "randomization":        { "type": "boolean", "default": true },
            "practice": {
              "type": "object",
              "properties": {
                "stimulus_duration":    { "type": "number", "minimum": 500, "maximum": 2000, "default": 1000 },
                "inter_trial_interval": { "type": "number", "minimum": 500, "maximum": 1500, "default": 1000 }
              }
            }
          }
        },
        "environment": {
          "type": "object",
          "properties": {
            "lighting":          { "type": "string", "enum": ["Controlled", "Dim"], "default": "Controlled" },
            "distraction_level": { "type": "string", "enum": ["Minimal", "Moderate"], "default": "Minimal" }
          }
        }
      }
    },
    "apparatus": {
      "type": "object",
      "properties": {
        "software":        { "type": "string", "enum": ["PsychoPy", "E-Prime", "MATLAB Psychtoolbox", "Custom"], "default": "PsychoPy" },
        "response_device": { "type": "string", "enum": ["Keyboard", "Response Pad", "Voice Key"], "default": "Keyboard" },
        "display": {
          "type": "object",
          "properties": {
            "resolution": { "type": "string" },
            "luminance":  { "type": "number", "minimum": 50, "maximum": 200, "default": 100 },
            "contrast":   { "type": "number", "minimum": 0.1, "maximum": 2.0, "default": 1.0 }
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "properties": {
        "behavioral": {
          "type": "object",
          "properties": {
            "reaction_time": {
              "type": "object",
              "properties": {
                "congruent":   { "type": "array", "items": { "type": "number", "minimum": 200, "maximum": 3000 } },
                "incongruent": { "type": "array", "items": { "type": "number", "minimum": 200, "maximum": 3000 } },
                "neutral":     { "type": "array", "items": { "type": "number", "minimum": 200, "maximum": 3000 } },
                "emotional":   { "type": "array", "items": { "type": "number", "minimum": 200, "maximum": 3000 } }
              }
            },
            "error_rate": {
              "type": "object",
              "properties": {
                "congruent":   { "type": "number", "minimum": 0, "maximum": 100, "default": 0 },
                "incongruent": { "type": "number", "minimum": 0, "maximum": 100, "default": 0 },
                "neutral":     { "type": "number", "minimum": 0, "maximum": 100, "default": 0 },
                "emotional":   { "type": "number", "minimum": 0, "maximum": 100, "default": 0 }
              }
            },
            "interference_score": { "type": "number", "minimum": 0, "default": 0 },
            "practice_effect": {
              "type": "object",
              "properties": {
                "rt_difference":    { "type": "number", "minimum": 0, "default": 0 },
                "error_difference": { "type": "number", "minimum": 0, "default": 0 }
              }
            }
          }
        },
        "data_analysis": {
          "type": "object",
          "properties": {
            "analysis_method": {
              "type": "string",
              "enum": ["ANOVA", "Mixed-effects modeling", "Regression", "t-test"],
              "default": "ANOVA"
            },
            "outlier_removal": {
              "type": "object",
              "properties": {
                "rt_threshold": {
                  "type": "object",
                  "properties": {
                    "min": { "type": "number", "minimum": 200, "default": 200 },
                    "max": { "type": "number", "minimum": 200, "maximum": 3000, "default": 3000 }
                  }
                },
                "sd_threshold": { "type": "number", "minimum": 1, "maximum": 3, "default": 2 }
              }
            }
          }
        }
      }
    },
    "neuroimaging": {
      "type": "object",
      "properties": {
        "eeg": {
          "type": "object",
          "properties": {
            "cap": {
              "type": "object",
              "properties": {
                "channels": { "type": "integer", "minimum": 32, "maximum": 128, "default": 64 },
                "system":   { "type": "string", "enum": ["10-20", "High-density"], "default": "10-20" }
              }
            },
            "sampling_rate": { "type": "number", "minimum": 500, "maximum": 1000, "default": 500 },
            "reference":     { "type": "string", "enum": ["Linked mastoids", "Average"], "default": "Linked mastoids" },
            "eog_channels":  { "type": "boolean" },
            "event_markers": {
              "type": "object",
              "properties": {
                "stimulus_onset": {
                  "type": "object",
                  "properties": {
                    "congruent":   { "type": "string" },
                    "incongruent": { "type": "string" },
                    "neutral":     { "type": "string" },
                    "emotional":   { "type": "string" }
                  }
                },
                "response_onset": { "type": "string" },
                "accuracy":       { "type": "string", "enum": ["correct", "incorrect"] }
              }
            },
            "components": {
              "type": "object",
              "properties": {
                "n200": {
                  "type": "object",
                  "properties": {
                    "latency": {
                      "type": "object",
                      "properties": {
                        "min": { "type": "number", "minimum": 200, "default": 200 },
                        "max": { "type": "number", "minimum": 200, "maximum": 350, "default": 350 }
                      }
                    },
                    "amplitude": { "type": "number" }
                  }
                },
                "n450": {
                  "type": "object",
                  "properties": {
                    "latency": {
                      "type": "object",
                      "properties": {
                        "min": { "type": "number", "minimum": 350, "default": 350 },
                        "max": { "type": "number", "minimum": 350, "maximum": 500, "default": 500 }
                      }
                    },
                    "amplitude": { "type": "number" }
                  }
                },
                "p300": {
                  "type": "object",
                  "properties": {
                    "latency": {
                      "type": "object",
                      "properties": {
                        "min": { "type": "number", "minimum": 300, "default": 300 },
                        "max": { "type": "number", "minimum": 300, "maximum": 600, "default": 600 }
                      }
                    },
                    "amplitude": { "type": "number" }
                  }
                },
                "lpc": {
                  "type": "object",
                  "properties": {
                    "latency": {
                      "type": "object",
                      "properties": {
                        "min": { "type": "number", "minimum": 500, "default": 500 }
                      }
                    },
                    "amplitude": { "type": "number" }
                  }
                }
              }
            }
          }
        },
        "fmri": {
          "type": "object",
          "properties": {
            "scanner": {
              "type": "object",
              "properties": {
                "model":      { "type": "string", "enum": ["3T", "7T"], "default": "3T" },
                "tr":         { "type": "number", "minimum": 2000, "maximum": 2500, "default": 2000 },
                "te":         { "type": "number", "minimum": 10, "maximum": 50, "default": 30 },
                "voxel_size": {
                  "type": "object",
                  "properties": {
                    "x": { "type": "number", "minimum": 2, "maximum": 3, "default": 3 },
                    "y": { "type": "number", "minimum": 2, "maximum": 3, "default": 3 },
                    "z": { "type": "number", "minimum": 2, "maximum": 3, "default": 3 }
                  }
                }
              }
            },
            "design":   { "type": "string", "enum": ["Event-related", "Block"], "default": "Event-related" },
            "contrast": { "type": "string" },
            "regions_of_interest": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "Anterior Cingulate Cortex (ACC)", "Dorsolateral Prefrontal Cortex (DLPFC)",
                  "Inferior Frontal Gyrus (IFG)", "Parietal Cortex", "Basal Ganglia"
                ]
              }
            }
          }
        }
      }
    },
    "cognitive_constructs": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Selective attention", "Executive control", "Inhibitory control",
          "Processing speed", "Conflict monitoring", "Emotional processing",
          "Response inhibition", "Language processing"
        ]
      },
      "default": ["Selective attention", "Executive control"]
    },
    "clinical_applications": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["ADHD", "Depression", "Schizophrenia", "Frontal lobe lesions", "Aging"]
      },
      "default": []
    }
  }
}
