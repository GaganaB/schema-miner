{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "StroopTaskProcess",
    "type": "object",
    "properties": {
        "task_type": {
            "type": "string",
            "enum": [
                "behavioral",
                "neuroimaging"
            ]
        },
        "core_process": {
            "type": "object",
            "properties": {
                "stimuli": {
                    "type": "object",
                    "enum": ["congruent", "incongruent", "neutral"],
                    "properties": {
                        "enum": ["word", "ink_color"],
                    },
                },
                "task_instruction": {
                    "type": "string"
                },
                "response_modality": {
                    "type": "string",
                    "enum": [
                        "verbal",
                        "manual"
                    ]
                },
                "congruency_rate": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                }
            },
            "required": [
                "stimuli",
                "task_instruction",
                "response_modality",
                "congruency_rate"
            ]
        },
        "experimental_settings": {
            "type": "object",
            "properties": {
                "stimulus_duration": {
                    "type": "number",
                    "minimum": 500,
                    "maximum": 2000,
                    "unit": "ms"
                },
                "inter_trial_interval": {
                    "type": "number",
                    "minimum": 500,
                    "maximum": 1500,
                    "unit": "ms"
                },
                "trials_per_condition": {
                    "type": "integer",
                    "minimum": 20
                },
                "stimulus_order": {
                    "type": "string",
                    "enum": [
                        "randomized",
                        "counterbalanced"
                    ]
                },
                "environment": {
                    "type": "string",
                    "enum": [
                        "controlled_lighting",
                        "minimal_distraction"
                    ]
                }
            },
            "required": [
                "stimulus_duration",
                "inter_trial_interval",
                "trials_per_condition",
                "stimulus_order"
            ]
        },
        "instruments": {
            "type": "object",
            "properties": {
                "software": {
                    "type": "string",
                    "enum": [
                        "PsychoPy",
                        "E-Prime",
                        "MATLAB_Psychtoolbox"
                    ]
                },
                "response_device": {
                    "type": "string",
                    "enum": [
                        "keyboard",
                        "response_pad",
                        "voice_key"
                    ]
                },
                "rt_precision": {
                    "type": "number",
                    "minimum": 0.001,
                    "unit": "ms"
                },
                "display": {
                    "type": "object",
                    "properties": {
                        "luminance": {
                            "type": "number",
                            "unit": "cd/m\u00b2"
                        },
                        "contrast": {
                            "type": "number",
                            "unit": "dimensionless"
                        }
                    }
                }
            },
            "required": [
                "software",
                "response_device",
                "rt_precision"
            ]
        },
        "outputs": {
            "type": "object",
            "properties": {
                "reaction_time": {
                    "type": "object",
                    "properties": {
                        "congruent": {
                            "type": "number",
                            "unit": "ms"
                        },
                        "incongruent": {
                            "type": "number",
                            "unit": "ms"
                        }
                    }
                },
                "error_rate": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 100,
                    "unit": "%"
                },
                "interference_score": {
                    "type": "number",
                    "unit": "ms"
                },
                "accuracy_adjusted_rt": {
                    "type": "number",
                    "unit": "ms"
                },
                "congruency_sequence_effect": {
                    "type": "number",
                    "unit": "ms"
                },
                "proportion_congruency_effect": {
                    "type": "number",
                    "unit": "ms"
                }
            },
            "required": [
                "reaction_time",
                "error_rate",
                "interference_score"
            ]
        },
        "neuroimaging": {
            "type": "object",
            "properties": {
                "eeg": {
                    "type": "object",
                    "properties": {
                        "channels": {
                            "type": "integer",
                            "minimum": 32,
                            "maximum": 128
                        },
                        "sampling_rate": {
                            "type": "number",
                            "minimum": 500,
                            "maximum": 1000,
                            "unit": "Hz"
                        },
                        "impedance": {
                            "type": "number",
                            "minimum": 5,
                            "maximum": 10000,
                            "unit": "k\u03a9"
                        },
                        "reference": {
                            "type": "string",
                            "enum": [
                                "linked_mastoids",
                                "average_reference"
                            ]
                        },
                        "eog_channels": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "event_markers": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "stimulus_onset",
                                    "response_onset",
                                    "accuracy"
                                ]
                            }
                        },
                        "midfrontal_theta": {
                            "type": "object",
                            "properties": {
                                "amplitude": {
                                    "type": "number",
                                    "unit": "\u03bcV"
                                },
                                "power": {
                                    "type": "number",
                                    "unit": "\u03bcV\u00b2"
                                }
                            }
                        }
                    }
                },
                "fMRI": {
                    "type": "object",
                    "properties": {
                        "scanner": {
                            "type": "string"
                        },
                        "tr": {
                            "type": "number",
                            "minimum": 2000,
                            "maximum": 2500,
                            "unit": "ms"
                        },
                        "te": {
                            "type": "number",
                            "minimum": 20,
                            "maximum": 50,
                            "unit": "ms"
                        },
                        "voxel_size": {
                            "type": "number",
                            "minimum": 2,
                            "maximum": 3,
                            "unit": "mm"
                        },
                        "design": {
                            "type": "string",
                            "enum": [
                                "event_related",
                                "block_design"
                            ]
                        },
                        "aMCC_activity": {
                            "type": "object",
                            "properties": {
                                "amplitude": {
                                    "type": "number",
                                    "unit": "percent_signal_change"
                                }
                            }
                        },
                        "preSMA_activity": {
                            "type": "object",
                            "properties": {
                                "amplitude": {
                                    "type": "number",
                                    "unit": "percent_signal_change"
                                }
                            }
                        }
                    }
                }
            }
        },
        "analysis_parameters": {
            "type": "object",
            "properties": {
                "outlier_exclusion": {
                    "type": "object",
                    "properties": {
                        "rt_outliers": {
                            "type": "object",
                            "properties": {
                                "lower_bound": {
                                    "type": "number",
                                    "minimum": 200,
                                    "unit": "ms"
                                },
                                "upper_bound": {
                                    "type": "number",
                                    "maximum": 3000,
                                    "unit": "ms"
                                }
                            }
                        }
                    }
                },
                "incorrect_trial_handling": {
                    "type": "string",
                    "enum": [
                        "exclude",
                        "adjust"
                    ]
                },
                "rt_normalization": {
                    "type": "object",
                    "properties": {
                        "method": {
                            "type": "string",
                            "enum": [
                                "z_score",
                                "percentile",
                                "rt_equalization"
                            ]
                        },
                        "parameters": {
                            "type": "object",
                            "properties": {
                                "z_score": {
                                    "type": "object",
                                    "properties": {
                                        "mean": {
                                            "type": "number"
                                        },
                                        "std_dev": {
                                            "type": "number"
                                        }
                                    }
                                },
                                "percentile": {
                                    "type": "object",
                                    "properties": {
                                        "lower_bound": {
                                            "type": "number",
                                            "minimum": 0,
                                            "maximum": 100
                                        },
                                        "upper_bound": {
                                            "type": "number",
                                            "minimum": 0,
                                            "maximum": 100
                                        }
                                    }
                                },
                                "rt_equalization": {
                                    "type": "object",
                                    "properties": {
                                        "congruent": {
                                            "type": "number",
                                            "minimum": 0,
                                            "maximum": 100
                                        },
                                        "incongruent": {
                                            "type": "number",
                                            "minimum": 0,
                                            "maximum": 100
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "required": [
                "outlier_exclusion",
                "incorrect_trial_handling",
                "rt_normalization"
            ]
        }
    },
    "required": [
        "task_type",
        "core_process",
        "experimental_settings",
        "instruments",
        "outputs",
        "analysis_parameters"
    ],
    "additionalProperties": false
}
