{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.com/schemas/stroop-task-process",
    "title": "Stroop Task Process Schema",
    "type": "object",
    "properties": {
        "task_type": {
            "type": "string",
            "enum": [
                "standard",
                "emotional",
                "numerical",
                "spatial",
                "bilingual",
                "clinical"
            ],
            "default": "standard"
        },
        "participants": {
            "type": "object",
            "properties": {
                "demographics": {
                    "type": "object",
                    "properties": {
                        "age_range": {
                            "type": "array",
                            "items": { "type": "number" },
                            "minItems": 2,
                            "maxItems": 2,
                            "default": [18, 65]
                        },
                        "sample_size": {
                            "type": "integer",
                            "minimum": 20,
                            "maximum": 200
                        },
                        "population": {
                            "type": "string",
                            "enum": ["adults", "children", "ADHD", "depression", "schizophrenia", "frontal_lesion", "aging"]
                        }
                    }
                },
                "proficiency": {
                    "type": "object",
                    "properties": {
                        "reading_proficiency": {
                            "type": "string",
                            "enum": ["basic", "intermediate", "advanced"],
                            "default": "intermediate"
                        },
                        "language_familiarity": {
                            "type": "string",
                            "enum": ["native", "second_language", "multilingual"],
                            "default": "native"
                        }
                    }
                }
            },
            "required": ["demographics"],
            "additionalProperties": false
        },
        "stimuli": {
            "type": "object",
            "properties": {
                "conditions": {
                    "type": "object",
                    "properties": {
                        "congruent": {
                            "type": "object",
                            "properties": {
                                "description": { "type": "string" },
                                "example": { "type": "string" }
                            },
                            "required": ["description"]
                        },
                        "incongruent": {
                            "type": "object",
                            "properties": {
                                "description": { "type": "string" },
                                "example": { "type": "string" }
                            },
                            "required": ["description"]
                        },
                        "neutral": {
                            "type": "object",
                            "properties": {
                                "description": { "type": "string" },
                                "example": { "type": "string" }
                            },
                            "required": ["description"]
                        }
                    },
                    "required": ["congruent", "incongruent", "neutral"]
                },
                "neuroimaging": {
                    "type": "object",
                    "properties": {
                        "eeg_fMRI": {
                            "type": "object",
                            "properties": {
                                "eeg_components": {
                                    "type": "array",
                                    "items": { "type": "string" }
                                },
                                "fMRI_regions": {
                                    "type": "array",
                                    "items": { "type": "string" }
                                }
                            }
                        },
                        "modeling_analysis": {
                            "type": "object",
                            "properties": {
                                "functional_connectivity": { "type": "string" },
                                "neural_coupling_measures": {
                                    "type": "array",
                                    "items": { "type": "string" }
                                },
                                "neurocomputational_model": {
                                    "type": "string",
                                    "enum": ["drift_diffusion_modeling", "botvinick_framework"]
                                },
                                "key_model_variables": {
                                    "type": "array",
                                    "items": { "type": "string" },
                                    "default": ["drift_rate", "decision_threshold", "conflict_signal_strength", "control_gain_modulation"]
                                }
                            }
                        }
                    },
                    "required": ["eeg_fMRI", "modeling_analysis"]
                }
            }
        },
        "clinical_applications": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": ["ADHD", "depression", "schizophrenia", "frontal_lobes_lesion", "aging"]
            },
            "default": ["ADHD", "depression", "schizophrenia", "frontal_lobes_lesion", "aging"]
        }
    },
    "required": [
        "task_type",
        "participants",
        "stimuli",
        "clinical_applications"
    ],
    "additionalProperties": false
}
