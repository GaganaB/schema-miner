{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Stroop Task Process",
    "type": "object",
    "required": [
        "task_type",
        "stimuli",
        "task_instructions",
        "experimental_settings",
        "instruments",
        "outputs",
        "cognitive_constructs",
        "data_analysis",
        "validity",
        "neuroimaging"
    ],
    "properties": {
        "task_type": {
            "type": "string",
            "enum": [
                "Emotional Stroop",
                "Numerical Stroop",
                "Spatial Stroop",
                "Bilingual Stroop",
                "Color-Word Stroop"
            ],
            "description": "Variant of the Stroop task being administered."
        },
        "stimuli": {
            "type": "object",
            "items": {
                "type": "object",
                "properties": {
                    "word": {
                            "type": "string"
                        },
                    "ink_color": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "word",
                        "ink_color"
                    ], 
                "enum": [
                    "congruent", 
                    "incongruent", 
                    "neutral"
                ]
                    },
                },
                "color_set": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                }
            },
        },
        "task_instructions": {
            "type": "object",
            "properties": {
                "response_modality": {
                    "type": "string",
                    "enum": [
                        "Verbal response",
                        "Manual keypress",
                    ],
                    "if": {
                        "properties": {
                            "condition": { "const": "manual keypress" },
                            "enum": [
                                "Standard keyboard",
                                "Response pad"
                            ]
                    }
                },
                    "then":{
                      "properties"{
                          "condition": {"const": "verbal response"},
                          "type": "boolean",
                      },  
                    },
                },
                "stimulus_description": {
                    "type": "array",
                    "items": {
                        "type": "string",
                    },
                }
            },
        },
        "experimental_settings": {
            "type": "object",
            "properties": {
                "stimulus_duration": {
                    "type": "integer",
                    "minimum": 500,
                    "maximum": 2000,
                    "unit": "ms"
                },
                "iti": {
                    "type": "integer",
                    "minimum": 500,
                    "maximum": 1500,
                    "unit": "ms"
                },
                "trials_per_condition": {
                    "type": "integer",
                    "minimum": 20,
                },
                "stimulus_order": {
                    "type": "string",
                    "enum": [
                        "Randomized",
                        "Counterbalanced"
                    ],
                },
                "environment": {
                    "type": "string",
                }
            },
        },
        "instruments": {
            "type": "object",
            "properties": {
                "software": {
                    "type": "string",
                    "enum": [
                        "PsychoPy",
                        "E-Prime",
                        "MATLAB Psychtoolbox"
                    ],
                },
                "display": {
                    "type": "object",
                    "properties": {
                        "luminance": {
                            "type": "number",
                            "type": "candelas per square meter."
                        },
                        "contrast": {
                            "type": "number",
                        }
                    },
                }
            },
        },
        "outputs": {
            "type": "object",
            "properties": {
                "reaction_time": {
                    "type": "object",
                    "properties": {
                        "type": "number",
                        "unit": "Mean RT in milliseconds."   
                    },
                },
                "error_rate": {
                    "type": "object",
                    "properties": {
                        "type": "number",
                        "unit": "percentage"
                    },
                },
                "interference_score": {
                    "type": "number",
                    "unit": "Difference in RT in milliseconds."
                }
            },
        },
        "cognitive_constructs": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "Selective attention",
                    "Executive control",
                    "Inhibitory control",
                    "Processing speed",
                    "Conflict monitoring"
                ]
            },
        },
        "data_analysis": {
            "type": "object",
            "properties": {
                "exclusion_criteria": {
                    "type": "object",
                    "properties": {
                        "rt_outliers": {
                            "type": "string",
                        },
                        "incorrect_responses": {
                            "type": "boolean",
                        }
                    },
                },
                "statistical_method": {
                    "type": "string",
                    "enum": [
                        "Within-subject ANOVA",
                        "Mixed-effects modeling"
                    ],
                }
            },
        },
        "validity": {
            "type": "object",
            "properties": {
                "construct_validity": {
                    "type": "string",
                },
                "sensitivity": {
                    "type": "string",
                },
                "influencing_factors": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                }
            },
        },
        "neuroimaging": {
            "type": "object",
            "properties": {
                "eeg": {
                    "type": "object",
                    "properties": {
                        "channels": {
                            "type": "integer",
                            "minimum": 32,
                            "maximum": 128,
                        },
                        "sampling_rate": {
                            "type": "integer",
                            "minimum": 500,
                            "maximum": 1000,
                            "unit": "Hz."
                        },
                        "impedance": {
                            "type": "number",
                            "minimum": 5,
                            "maximum": 10,
                            "unit": "kOhms."
                        },
                        "reference_type": {
                            "type": "string",
                            "enum": [
                                "Linked mastoids",
                                "Average reference"
                            ],
                        },
                        "event_markers": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "Stimulus onset",
                                    "Response onset",
                                    "Accuracy coding"
                                ]
                            },
                            "description": "Event markers recorded during EEG."
                        },
                        "components": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "enum": [
                                            "N200",
                                            "N450",
                                            "P300",
                                            "Late Positive Component (LPC)"
                                        ]
                                    },
                                    "latency": {
                                        "type": "object",
                                        "properties": {
                                            "min": {
                                                "type": "number",
                                                "unit": "milliseconds."
                                            },
                                            "max": {
                                                "type": "number",
                                                "unit": "milliseconds."
                                            }
                                        }
                                    },
                                    "component_interpretation": {
                                        "type": "string",
                                    }
                                },
                                "required": [
                                    "name",
                                    "latency",
                                    "component_interpretation"
                                ]
                            },
                        }
                    },
                },
                "fmri": {
                    "type": "object",
                    "properties": {
                        "scanner": {
                            "type": "string",
                        },
                        "parameters": {
                            "type": "object",
                            "properties": {
                                "TR": {
                                    "type": "number",
                                    "unit": "milliseconds."
                                },
                                "TE": {
                                    "type": "number",
                                    "unit": "milliseconds."
                                },
                                "voxel_size": {
                                    "type": "string",
                                    "unit": "millimeters"
                                    "enum": [
                                        "x",
                                        "y", 
                                        "z"
                                    ],
                                }
                            },
                        },
                        "design": {
                            "type": "string",
                            "enum": [
                                "Event-related",
                                "Block design"
                            ],
                        },
                        "brain_regions": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "region": {
                                        "type": "string",
                                        "enum": [
                                            "Anterior Cingulate Cortex (ACC)",
                                            "Dorsolateral Prefrontal Cortex (DLPFC)",
                                            "Inferior Frontal Gyrus",
                                            "Parietal Cortex",
                                            "Basal Ganglia"
                                        ]
                                    },
                                    "func_role": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "region",
                                    "func_role"
                                ]
                            },
                        },
                        "expected_contrast": {
                            "type": "string"
                        }
                    },
                },
                "connectivity_analysis": {
                    "type": "object",
                    "properties": {
                        "functional_connectivity": {
                            "type": "string"
                        },
                        "network_engagement": {
                            "type": "string"
                        }
                    },
                },
                "behavioral_neural_coupling": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "measure": {
                                "type": "string",
                                "enum": [
                                    "Correlation between interference score and ACC activation",
                                    "N450 amplitude vs. reaction time slowing",
                                    "Theta power increase vs. error likelihood",
                                    "Trial-by-trial conflict adaptation (Gratton effect)"
                                ]
                            },
                            "description": {
                                "type": "string",
                            }
                        },
                        "required": [
                            "measure",
                            "description"
                        ]
                    },
                },
                "neurocomputational_modeling": {
                    "type": "object",
                    "properties": {
                        "model_type": {
                            "type": "string",
                            "enum": [
                                "Parallel processing streams",
                                "Competitive inhibition dynamics",
                                "Drift diffusion modeling (DDM)",
                                "Conflict monitoring models (Botvinick framework)"
                            ],
                        },
                        "variables": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "enum": [
                                            "Drift rate",
                                            "Decision threshold",
                                            "Conflict signal strength",
                                            "Control gain modulation"
                                        ]
                                    },
                                    "description": {
                                        "type": "string",
                                    }
                                },
                                "required": [
                                    "name",
                                    "description"
                                ]
                            },
                        }
                    },
                },
                "clinical_applications": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "ADHD research",
                            "Depression",
                            "Schizophrenia",
                            "Frontal lobe lesion studies",
                            "Aging research"
                        ]
                    },
                }
            }
        }
    }
}
