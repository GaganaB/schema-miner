{
    "stroop_task": {
        "properties": {
            "participants": {
                "type": "object",
                "properties": {
                    "sample_size": {
                        "type": "integer",
                        "minimum": 20,
                        "maximum": 200,
                        "default": 50
                    },
                    "age_range": {
                        "type": "array",
                        "items": {
                            "type": "integer",
                            "minimum": 18,
                            "maximum": 65
                        },
                        "default": [
                            18,
                            65
                        ]
                    },
                    "gender": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "enum": [
                                "male",
                                "female",
                                "non-binary",
                                "other"
                            ]
                        }
                    },
                    "language_proficiency": {
                        "type": "string",
                        "default": "native"
                    },
                    "gender_identity": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "enum": [
                                "man",
                                "woman",
                                "non-binary",
                                "other"
                            ]
                        }
                    }
                }
            },
            "stimuli": {
                "type": "object",
                "properties": {
                    "stimulus_type": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "enum": [
                                "congruent",
                                "incongruent",
                                "neutral"
                            ]
                        }
                    },
                    "stimulus_duration": {
                        "unit": "milliseconds",
                        "type": "number",
                        "minimum": 500,
                        "maximum": 2000,
                        "default": 1000
                    },
                    "inter_trial_interval": {
                        "unit": "milliseconds",
                        "type": "number",
                        "minimum": 500,
                        "maximum": 1500,
                        "default": 1000
                    },
                    "colors": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "enum": [
                                "red",
                                "blue",
                                "green",
                                "yellow",
                                "purple"
                            ]
                        },
                        "default": [
                            "red",
                            "blue",
                            "green",
                            "yellow"
                        ]
                    },
                    "words": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "red",
                            "blue",
                            "green",
                            "yellow"
                        ]
                    },
                    "neutral_stimuli": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "XXXX",
                            "****",
                            "###"
                        ]
                    }
                }
            },
            "task_instructions": {
                "type": "object",
                "properties": {
                    "response_type": {
                        "type": "string",
                        "enum": [
                            "verbal",
                            "manual"
                        ]
                    },
                    "response_mapping": {
                        "type": "object",
                        "properties": {
                            "type": "string", 
                            "enum": ["verbal", "manual"],
                        }
                    },
                    "task_condition": {
                        "type": "string",
                        "enum": [
                            "color_naming",
                            "word_reading"
                        ]
                    }
                }
            },
            "experimental_settings": {
                "type": "object",
                "properties": {
                    "trial_count": {
                        "type": "integer",
                        "minimum": 20,
                        "maximum": 100,
                        "default": 50
                    },
                    "stimulus_order": {
                        "type": "string",
                        "enum": [
                            "randomized",
                            "counterbalanced"
                        ]
                    },
                    "environment": {
                        "type": "string",
                        "default": "controlled"
                    }
                }
            },
            "instruments": {
                "type": "object",
                "properties": {
                    "software": {
                        "type": "string"
                    },
                    "response_device": {
                        "type": "string"
                    },
                    "display": {
                        "type": "object",
                        "properties": {
                            "luminance": {
                                "unit": "candelas per square meter",
                                "type": "number",
                                "minimum": 100,
                                "default": 200
                            },
                            "contrast": {
                                "type": "number",
                                "minimum": 1,
                                "default": 10
                            }
                        }
                    },
                    "reaction_time_precision": {
                        "unit": "milliseconds (ms).",
                        "type": "number",
                        "minimum": 1,
                        "default": 1
                    }
                }
            },
            "primary_outputs": {
                "type": "object",
                "properties": {
                    "reaction_time": {
                        "unit": "milliseconds (ms).",
                        "type": "array",
                        "items": {
                            "type": "number",
                            "minimum": 200,
                            "maximum": 3000
                        }
                    },
                    "error_rate": {
                        "unit": "percentage (%).",
                        "type": "array",
                        "items": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 100
                        }
                    },
                    "interference_score": {
                        "unit": "milliseconds (ms).",
                        "type": "number"
                    },
                    "accuracy_adjusted_rt": {
                        "type": "number"
                    }
                }
            },
            "expected_behavioral_pattern": {
                "type": "object",
                "properties": {
                    "incongruent_rt": {
                        "type": "number"
                    },
                    "increased_error_rate": {
                        "type": "number"
                    },
                    "interference_effect": {
                        "type": "boolean",
                        "default": true
                    }
                }
            },
            "reliability_characteristics": {
                "type": "object",
                "properties": {
                    "test_retest_reliability": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100,
                        "default": 70
                    },
                    "group_level_effects": {
                        "type": "boolean",
                        "default": true
                    }
                }
            },
            "cognitive_constructs": {
                "type": "array",
                "items": {
                    "type": "string",
                    "enum": [
                        "selective_attention",
                        "executive_control",
                        "inhibitory_control",
                        "processing_speed",
                        "conflict_monitoring"
                    ]
                }
            },
            "data_analysis": {
                "type": "object",
                "properties": {
                    "outlier_exclusion": {
                        "type": "string"
                    },
                    "rt_analysis": {
                        "type": "boolean",
                        "default": true
                    },
                    "analysis_method": {
                        "type": "string",
                        "enum": [
                            "within_subject_anova",
                            "mixed_effects_modeling"
                        ]
                    }
                }
            },
            "validity_notes": {
                "type": "object",
                "properties": {
                    "construct_validity": {
                        "type": "boolean",
                        "default": true
                    },
                    "sensitivity_frontallobe": {
                        "type": "boolean",
                        "default": true
                    },
                    "influence": {
                        "type": "boolean",
                        "default": true
                    }
                }
            },
            "neuroimaging": {
                "type": "object",
                "properties": {
                    "eeg": {
                        "type": "object",
                        "properties": {
                            "capacity": {
                                "type": "number",
                                "minimum": 32,
                                "maximum": 128
                            },
                            "sampling_rate": {
                                "unit": "Hz",
                                "type": "number",
                                "minimum": 500,
                                "maximum": 1000,
                                "default": 500
                            },
                            "impedance": {
                                "type": "number",
                                "minimum": 5000,
                                "maximum": 10000,
                                "default": 7500
                            },
                            "reference": {
                                "type": "string"
                            },
                            "eog_channels": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            },
                            "event_markers": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "fMRI": {
                        "type": "object",
                        "properties": {
                            "scanner_type": {
                                "type": "string"
                            },
                            "tr": {
                                "unit": "ms",
                                "type": "number",
                                "minimum": 2000,
                                "maximum": 2500,
                                "default": 2000
                            },
                            "te": {
                                "unit": "ms",
                                "type": "number",
                                "minimum": 20,
                                "maximum": 40,
                                "default": 30
                            },
                            "voxel_size": {
                                "unit": "mm",
                                "type": "number",
                                "minimum": 2,
                                "maximum": 3,
                                "default": 2.5
                            },
                            "design_option": {
                                "type": "string",
                                "enum": [
                                    "event_related",
                                    "block_design"
                                ]
                            }
                        }
                    },
                    "connectivity_analysis": {
                        "type": "object",
                        "properties": {
                            "type": "string", 
                            "enum": [
                            "functional_connectivity",
                            "theta_band_power",
                            "eeg_coherence",
                            "effective_connectivity"
                            ]
                        }
                    },
                    "behavioral_neural_coupling": {
                        "type": "object",
                        "properties": {
                            "type": "string",
                            "enum": [
                            "acc_activation",
                            "n450_amplitude",
                            "theta_power_increase",
                            "conflict_adaptation"
                                ]
                        }
                    }
                }
            },
            "clinical_applications": {
               "type": "object",
                "properties": {
                    "applications": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "enum": [
                                "adhd",
                                "depression",
                                "schizophrenia",
                                "frontal_lobe_lesion",
                                "aging"
                            ]
                        }
                    },
                    "neuro_extensions": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            },
            "neurocomputational_modeling": {
                "type": "object",
                "properties": {
                    "model_type": {
                        "type": "string",
                        "enum": [
                            "parallel_processing_streams",
                            "drift_diffusion_modeling",
                            "conflict_monitoring"
                        ]
                    },
                    "key_variables": {
                        "type": "object",
                        "properties": {
                            "type": "number", 
                            "enum":[
                            "drift_rate", 
                            "decision_threshold",
                            "conflict_signal_strength",
                            "control_gain_modulation"
                            ]
                        }
                    }
                }
            }
        },
        "required": [
            "participants",
            "stimuli",
            "task_instructions",
            "experimental_settings",
            "instruments",
            "primary_outputs",
            "expected_behavioral_pattern",
            "reliability_characteristics",
            "cognitive_constructs",
            "data_analysis",
            "validity_notes"
        ]
    }
}
