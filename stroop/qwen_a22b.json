{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Stroop Task Process Schema",
    "type": "object",
    "required": [
        "taskVariant",
        "stimuli",
        "taskInstructions",
        "experimentalSettings",
        "instruments",
        "outputs",
        "cognitiveConstructs"
    ],
    "properties": {
        "taskVariant": {
            "type": "string",
            "enum": [
                "Standard",
                "Emotional Stroop",
                "Numerical Stroop",
                "Spatial Stroop",
                "Bilingual Stroop",
                "Clinical Adaptation"
            ]
        },
        "sampleCharacteristics": {
            "type": "object",
            "properties": {
                "ageRange": {
                    "type": "array",
                    "items": {
                        "type": "integer",
                        "minimum": 0
                    },
                    "minItems": 2,
                    "maxItems": 2
                },
                "population": {
                    "type": "string",
                    "enum": ["healthy controls", "clinical groups"]
                },
                "sampleSize": {
                    "type": "integer",
                    "minimum": 1
                }
            },
            "required": [
                "ageRange",
                "sampleSize"
            ]
        },
        "stimuli": {
            "type": "object",
            "description": "Stimulus properties and configuration",
            "properties": {
                "type": "array",
                "items": {
                        "type": "string"
                    },
                "enum": ["congruent", "incongruent", "neutral"],
                },
                "colorSet": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "minItems": 3,
                    "maxItems": 6,
                    "enum": [
                        [
                            "red",
                            "blue",
                            "green",
                            "yellow"
                        ]
                    ]
                }
            },
            "required": [
                "congruent",
                "incongruent",
                "colorSet"
            ]
        },
        "taskInstructions": {
            "type": "object",
            "properties": {
                "responseMapping": {
                    "type": "string",
                    "enum": [
                        "ink color",
                        "word"
                    ],
                },
                "responseModality": {
                    "type": "string",
                    "enum": [
                        "Verbal (voice key)",
                        "Manual keypress"
                    ],
                }
            },
            "required": [
                "responseMapping",
                "responseModality"
            ]
        },
        "experimentalSettings": {
            "type": "object",
            "properties": {
                "stimulusDuration": {
                    "type": "number",
                    "unit": "ms",
                    "minimum": 0,
                    "maximum": 2000,
                    "default": 0,
                },
                "interTrialInterval": {
                    "type": "number",
                    "unit": "ms",
                    "minimum": 100,
                    "maximum": 1500,
                    "default": 1000,
                },
                "trialsPerCondition": {
                    "type": "integer",
                    "minimum": 10,
                    "default": 40
                },
                "randomization": {
                    "type": "string",
                    "description": "Stimulus order methodology",
                    "enum": [
                        "Randomized",
                        "Counterbalanced",
                        "Blocked"
                    ],
                    "default": "Randomized",
                },
                "environment": {
                    "type": "string",
                    "enum": ["Controlled lighting, minimal distraction", "Sound-attenuated booth, 50 lux illumination"],
                }
            },
            "required": [
                "trialsPerCondition"
            ]
        },
        "instruments": {
            "type": "object",
            "properties": {
                "software": {
                    "type": "string",
                    "enum": [
                        "PsychoPy",
                        "E-Prime",
                        "MATLAB Psychtoolbox"
                    ]
                },
                "responseDevice": {
                    "type": "string",
                    "enum": [
                        "Cedrus RB-830 response pad",
                        "Standard keyboard"
                    ]
                },
                "voiceKey": {
                    "type": "boolean",
                    "default": false
                },
                "displayCalibration": {
                    "type": "string",
                    "default": "Calibrated for consistent luminance and contrast",
                },
                "timingPrecision": {
                    "type": "string",
                    "default": "Millisecond resolution",
                }
            },
            "required": [
                "software"
            ]
        },
        "outputs": {
            "type": "object",
            "properties": {
                "reactionTime": {
                    "type": "object",
                    "properties": {
                        "unit": {
                            "type": "string",
                            "units": "ms"
                        },
                        "type": "number",
                        "enum": ["congruent", "incongruent", "neutral"]
                        }
                    },
                    "required": [
                        "congruent",
                        "incongruent"
                    ]
                },
                "errorRate": {
                    "type": "object",
                    "properties": {
                        "unit": {
                            "type": "string",
                            "enum": [
                                "%"
                            ],
                            "default": "%"
                        },
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100, 
                        "enum": ["congruent", "incongruent", "neutral"]
                    },
                    "required": [
                        "congruent",
                        "incongruent"
                    ]
                },
                "interferenceScore": {
                    "type": "number",
                    "description": "Primary interference metric: RT(incongruent) - RT(congruent)",
                    "unit": "ms"
                },
                "accuracyAdjustedRT": {
                    "type": "number",
                    "description": "Composite metric combining speed and accuracy (e.g., IES = RT / (1 - error rate))",
                    "unit": "ms"
                }
            },
            "required": [
                "reactionTime",
                "errorRate",
                "interferenceScore"
            ]
        },
        "cognitiveConstructs": {
            "type": "array",
            "description": "Cognitive processes measured by the task",
            "items": {
                "type": "string",
                "enum": [
                    "Selective attention",
                    "Executive control",
                    "Inhibitory control",
                    "Processing speed",
                    "Conflict monitoring"
                ]
            },
            "minItems": 2,
        },
        "expectedBehavioralPattern": {
            "type": "string",
            "default": "Incongruent trials produce significantly longer RTs and higher error rates than congruent trials",
        },
        "reliabilityCharacteristics": {
            "type": "string",
            "default": "Moderate-to-high reliability; improves with increased trial count (>60 trials/condition)",
        },
        "dataAnalysisNorms": {
            "type": "object",
            "properties": {
                "outlierExclusion": {
                    "type": "string",
                    "default": "Trials <200ms or >3000ms excluded; \u00b12.5 SD within subject",
                },
                "incorrectTrialRemoval": {
                    "type": "boolean",
                    "default": true
                },
                "statisticalMethods": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "Within-subject ANOVA",
                            "Mixed-effects modeling",
                            "t-test (congruent vs incongruent)"
                        ]
                    },
                    "default": [
                        "Within-subject ANOVA"
                    ]
                }
            }
        },
        "validityNotes": {
            "type": "object",
            "properties": {
                "type": "string",
                "constructValidity": {
                    "default": "Strong validity for interference control and inhibitory processes"
                },
                "sensitivity": {
                    "default": "Sensitive to frontal lobe dysfunction and executive control deficits",
                },
                "influencingFactors": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "Reading proficiency",
                        "Language familiarity",
                        "Color vision acuity"
                    ]
                }
            }
        },
        "neuroimaging": {
            "type": "object",
            "description": "Neurophysiological implementation details (optional extension)",
            "properties": {
                "eeg": {
                    "type": "object",
                    "properties": {
                        "channels": {
                            "type": "integer",
                            "minimum": 16,
                            "maximum": 256
                        },
                        "samplingRate": {
                            "type": "number",
                            "unit": "Hz",
                            "minimum": 250
                        },
                        "keyComponents": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "type": "string",
                                    "enum": ["component", "latencyRange(ms)", "interpretation"], 
                                },
                            },
                                "required": [
                                    "component",
                                    "latencyRange"
                                ]
                            },
                        }
                    }
                },
                "fmri": {
                    "type": "object",
                    "properties": {
                        "fieldStrength": {
                            "type": "number",
                            "unit": "T",
                            "enum": [
                                1.5,
                                3,
                                7
                            ],
                            "default": 3
                        },
                        "tr": {
                            "type": "number",
                            "unit": "ms",
                        },
                        "keyRegions": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "type": "string",
                                    "enum": ["region", "functionalRole"],
                                },
                                "required": [
                                    "region",
                                    "functionalRole"
                                ]
                            },
                        }
                    }
                },
                "behavioralNeuralCoupling": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                }
            }
        }
    }
}
