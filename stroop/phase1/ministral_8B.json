{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Stroop Task Process Schema",
    "description": "A schema representing the Stroop task process, including behavioral, neuroimaging, and neurocomputational components.",
    "type": "object",
    "properties": {
        "metadata": {
            "type": "object",
            "properties": {
                "experiment_id": {
                    "type": "string",
                },
                "variant": {
                    "type": "string",
                    "enum": [
                        "Standard",
                        "Emotional",
                        "Numerical",
                        "Spatial",
                        "Bilingual"
                    ]
                },
                "sample": {
                    "type": "object",
                    "properties": {
                        "age_range": {
                            "type": "object",
                            "properties": {
                                "min": {
                                    "type": "number"
                                },
                                "max": {
                                    "type": "number"
                                }
                            },
                            "required": [
                                "min",
                                "max"
                            ]
                        },
                        "sample_size": {
                            "type": "integer",
                            "minimum": 20
                        },
                        "clinical_population": {
                            "type": "boolean"
                        }
                    }
                }
            },
            "required": [
                "variant"
            ]
        },
        "stimuli": {
            "type": "object",
            "properties": {
                "color_set": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "red",
                            "blue",
                            "green",
                            "yellow",
                            "black",
                            "white"
                        ]
                    },
                    "minItems": 3,
                    "maxItems": 6
                },
                "stimulus_types": {
                    "type": "object",
                    "properties": {
                        "congruent": {
                            "type": "boolean",
                            },
                        "incongruent": {
                            "type": "boolean",
                            },
                        "neutral": {
                            "type": "boolean",
                           }
                    },
                    "required": [
                        "congruent",
                        "incongruent",
                        "neutral"
                    ]
                },
                "word_list": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "required": [
                "color_set"
            ]
        },
        "task_instructions": {
            "type": "object",
            "properties": {
                "response_modality": {
                    "type": "string",
                    "enum": [
                        "verbal",
                        "manual"
                    ]
                },
                "response_mapping": {
                    "type": "string",
                    "enum": [
                        "name_color",
                        "read_word"
                    ]
                },
                "response_keys": {
                    "type": "object",
                    "properties": {
                        "type": "string", 
                        "enum":[
                        "red", 
                        "blue", 
                        "green", 
                        "yellow"
                    ],
                    }
                }
            },
            "required": [
                "response_modality",
                "response_mapping"
            ]
        },
        "experimental_settings": {
            "type": "object",
            "properties": {
                "stimulus_duration": {
                    "type": "object",
                    "description": "Duration of stimulus presentation (in milliseconds).",
                    "properties": {
                        "min": {
                            "type": "integer",
                            "minimum": 500
                        },
                        "max": {
                            "type": "integer",
                            "maximum": 2000
                        }
                    },
                    "required": [
                        "min",
                        "max"
                    ]
                },
                "inter_trial_interval": {
                    "type": "object",
                    "description": "Inter-trial interval (in milliseconds).",
                    "properties": {
                        "min": {
                            "type": "integer",
                            "description": "Minimum ITI (ms).",
                            "minimum": 500
                        },
                        "max": {
                            "type": "integer",
                            "description": "Maximum ITI (ms).",
                            "maximum": 1500
                        }
                    },
                    "required": [
                        "min",
                        "max"
                    ]
                },
                "trials_per_condition": {
                    "type": "object",
                    "description": "Number of trials per condition.",
                    "properties": {
                        "congruent": {
                            "type": "integer",
                            "minimum": 20
                        },
                        "incongruent": {
                            "type": "integer",
                            "minimum": 20
                        },
                        "neutral": {
                            "type": "integer",
                            "minimum": 0
                        }
                    },
                    "required": [
                        "congruent",
                        "incongruent"
                    ]
                },
                "randomization": {
                    "type": "boolean",
                    "enum":[
                        "randomised", 
                        "counterbalanced"
                    ]
                }
            },
            "required": [
                "stimulus_duration",
                "inter_trial_interval",
                "trials_per_condition"
            ]
        },
        "instruments": {
            "type": "object",
            "properties": {
                "software": {
                    "type": "string",
                    "enum": [
                        "PsychoPy",
                        "E-Prime",
                        "MATLAB_Psychtoolbox",
                        "Other"
                    ]
                },
                "response_device": {
                    "type": "string",
                    "enum": [
                        "keyboard",
                        "response_pad", 
                        "verbal"
                    ]
                },
                "voice_recording": {
                    "type": "boolean",
                },
                "reaction_time_precision": {
                    "type": "string",
                    "enum": [
                        "millisecond"
                    ]
                },
                "display_calibration": {
                    "type": "boolean",
                }
            },
            "required": [
                "software",
                "response_device"
            ]
        },
        "behavioral_outputs": {
            "type": "object",
            "properties": {
                "reaction_times": {
                    "type": "object",
                    "enum": [
                        "millisecond"
                    ],
                    "properties": {
                        "congruent": {
                            "type": "array",
                            "items": {
                                "type": "number",
                                "minimum": 0
                            }
                        },
                        "incongruent": {
                            "type": "array",
                            "items": {
                                "type": "number",
                                "minimum": 0
                            }
                        },
                        "neutral": {
                            "type": "array",
                            "items": {
                                "type": "number",
                                "minimum": 0
                            }
                        }
                    }
                },
                "error_rates": {
                    "type": "object",
                    "enum": [
                        "percentage"
                    ]
                    "properties": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100
                },
                "interference_score": {
                    "type": "number",
                    "description": "Interference score calculated as RT(incongruent) - RT(congruent).",
                    "minimum": 0
                }
            },
            "required": [
                "reaction_times",
                "error_rates",
                "interference_score"
            ]
        },
        "neuroimaging": {
            "type": "object",
            "description": "Neuroimaging data collection parameters.",
            "properties": {
                "modality": {
                    "type": "string",
                    "enum": [
                        "EEG",
                        "fMRI",
                        "None"
                    ]
                },
                "eeg": {
                    "type": "object",
                    "properties": {
                        "channels": {
                            "type": "integer",
                            "minimum": 32,
                            "maximum": 128
                        },
                        "sampling_rate": {
                            "type": "integer",
                            "enum": ["Hertz"],
                            "minimum": 500
                        },
                        "impedance": {
                            "type": "object",
                            "properties": {
                                "max": {
                                    "type": "number",
                                    "minimum": 5,
                                    "maximum": 10
                                }
                            },
                            "required": [
                                "max"
                            ]
                        },
                        "reference": {
                            "type": "string",
                            "enum": [
                                "linked_mastoids",
                                "average"
                            ]
                        },
                        "event_markers": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "stimulus_onset",
                                    "response_onset",
                                    "accuracy"
                                ]
                            }
                        }
                    }
                },
                "fMRI": {
                    "type": "object",
                    "description": "fMRI-specific parameters.",
                    "properties": {
                        "scanner": {
                            "type": "string",
                            "enum": [
                                "3T"
                            ]
                        },
                        "tr": {
                            "type": "integer",
                            "enum": ["ms"],
                            "minimum": 2000,
                            "maximum": 2500
                        },
                        "te": {
                            "type": "integer",
                            "enum": ["ms"],
                            "minimum": 20,
                            "maximum": 50
                        },
                        "voxel_size": {
                            "type": "object",
                            "enum": ["mm"],
                            "minimum": 2,
                            "maximum": 3,
                            "properties": {
                                "x": {
                                    "type": "number" 
                                },
                                "y": {
                                    "type": "number"
                                },
                                "z": {
                                    "type": "number"
                                }
                            },
                            "required": [
                                "x",
                                "y",
                                "z"
                            ]
                        },
                        "design": {
                            "type": "string",
                            "enum": [
                                "event_related",
                                "block"
                            ]
                        }
                    }
                }
            }
        },
        "neurocomputational_model": {
            "type": "object",
            "properties": {
                "model_type": {
                    "type": "string",
                    "enum": [
                        "drift_diffusion",
                        "conflict_monitoring",
                        "None"
                    ]
                },
                "drift_diffusion": {
                    "type": "object",
                    "properties": {
                        "drift_rate": {
                            "type": "number"
                            },
                        "decision_threshold": {
                            "type": "number"
                           },
                        "non_decision_time": {
                            "type": "number"
                            }
                    }
                },
                "conflict_monitoring": {
                    "type": "object",
                    "properties": {
                        "conflict_signal_strength": {
                            "type": "number",
                            },
                        "control_gain": {
                            "type": "number",
                           }
                    }
                }
            }
        },
        "data_analysis": {
            "type": "object",
            "properties": {
                "outlier_removal": {
                    "type": "object",
                    "properties": {
                        "threshold_sd": {
                            "type": "number",
                            "description": "Standard deviation threshold for outlier removal (e.g., \u00b12).",
                            "minimum": 1
                        },
                        "min_reactiontime": {
                            "type": "integer",
                            "enum":["ms"],
                            "minimum": 200
                        },
                        "max_reactiontime": {
                            "type": "integer",
                            "enum":["ms"],
                            "minimum": 2000
                        }
                    }
                },
                "accuracy_adjustment": {
                    "type": "boolean",
                    },
                "statistical_method": {
                    "type": "string",
                    "enum": [
                        "within_subject_anova",
                        "mixed_effects",
                        "other"
                    ]
                }
            },
            "required": [
                "outlier_removal"
            ]
        },
        "clinical_applications": {
            "type": "object",
            "properties": {
                "diagnosis": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "ADHD",
                            "depression",
                            "schizophrenia",
                            "frontal_lobe_dysfunction",
                            "aging"
                        ]
                    }
                },
                "behavioral_neural_coupling": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        }
    },
    "required": [
        "metadata",
        "stimuli",
        "task_instructions",
        "experimental_settings",
        "instruments",
        "behavioral_outputs"
    ]
}

