{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "StroopTaskProcess",
    "type": "object",
    "properties": {
        "taskType": {
            "type": "string",
            "enum": [
                "Standard Stroop",
                "Emotional Stroop",
                "Numerical Stroop",
                "Spatial Stroop",
                "Bilingual Stroop",
                "Clinical Adaptation"
            ],
            "description": "The variant of the Stroop task being implemented. Determines stimulus content and cognitive demands."
        },
        "stimuli": {
            "type": "object",
            "properties": {
                "stimulusTypes": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "Congruent",
                            "Incongruent",
                            "Neutral"
                        ]
                    },
                    "minItems": 1,
                },
                "colorSet": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "red",
                            "blue",
                            "green",
                            "yellow",
                            "black",
                            "white"
                        ]
                    },
                    "minItems": 3,
                    "maxItems": 6,
                },
                "wordContent": {
                    "type": "object",
                    "properties": {
                        "type": "array",
                        "enum": ["congruent", "incongruent", "neutral"],
                        "items": {
                                "type": "string"
                            },
                    },
                    "required": [
                        "congruent",
                        "incongruent",
                        "neutral"
                    ]
                },
                "stimulusDuration": {
                    "type": "number",
                    "minimum": 500,
                    "maximum": 2000,
                    "unit": "milliseconds",
                   },
                "interTrialInterval": {
                    "type": "number",
                    "minimum": 500,
                    "maximum": 1500,
                    "unit": "milliseconds",
                },
                "trialCountPerCondition": {
                    "type": "integer",
                    "minimum": 20,
                    "maximum": 100,
               },
                "stimulusOrder": {
                    "type": "string",
                    "enum": [
                        "randomized",
                        "counterbalanced"
                    ]
                }
            },
            "required": [
                "stimulusTypes",
                "colorSet",
                "wordContent",
                "stimulusDuration",
                "interTrialInterval",
                "trialCountPerCondition",
                "stimulusOrder"
            ]
        },
        "taskInstruction": {
            "type": "object",
            "properties": {
                "responseMapping": {
                    "type": "string",
                    "enum": [
                        "ink color",
                        "word"
                    ],
                },
                "responseModality": {
                    "type": "string",
                    "enum": [
                        "verbal",
                        "manual"
                    ],
                },
                "responseKeyMapping": {
                    "type": "object",
                    "properties": {
                        "type": "string",
                        "enum": ["red", "blue", "green", "yellow", "black", "white"],
                    },
                    "additionalProperties": false
                }
            },
            "required": [
                "responseMapping",
                "responseModality"
            ]
        },
        "experimentalSettings": {
            "type": "object",
            "properties": {
                "environment": {
                    "type": "object",
                    "properties": {
                        "lighting": {
                            "type": "string",
                            "enum": [
                                "controlled",
                                "dim",
                                "standard"
                            ],
                        },
                        "distractionLevel": {
                            "type": "string",
                            "enum": [
                                "minimal",
                                "none",
                                "low"
                            ],
                        }
                    },
                    "required": [
                        "lighting",
                        "distractionLevel"
                    ]
                },
                "displayCalibration": {
                    "type": "object",
                    "properties": {
                        "luminance": {
                            "type": "number",
                            "minimum": 0,
                            "unit": "cd/m\u00b2"
                        },
                        "contrast": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1,
                            "unit": "ratio"
                        },
                        "resolution": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "luminance",
                        "contrast",
                        "resolution"
                    ]
                }
            },
            "required": [
                "environment",
                "displayCalibration"
            ]
        },
        "instruments": {
            "type": "object",
            "properties": {
                "software": {
                    "type": "string",
                    "enum": [
                        "PsychoPy",
                        "E-Prime",
                        "MATLAB Psychtoolbox",
                        "OpenSesame",
                        "Presentation",
                        "Custom"
                    ],
                 },
                "responseDevice": {
                    "type": "string",
                    "enum": [
                        "standard keyboard",
                        "response pad",
                        "touchscreen",
                        "custom"
                    ],
                },
                "voiceKey": {
                    "type": "object",
                    "properties": {
                        "microphone": {
                            "type": "string",
                        },
                        "samplingRate": {
                            "type": "integer",
                            "minimum": 16000,
                            "unit": "Hz"
                        }
                    },
                    "required": [
                        "microphone",
                        "samplingRate"
                    ]
                },
                "rtPrecision": {
                    "type": "string",
                    "enum": [
                        "millisecond",
                        "microsecond"
                    ],
                }
            },
            "required": [
                "software",
                "responseDevice",
                "voiceKey",
                "rtPrecision"
            ]
        },
        "primaryOutputs": {
            "type": "object",
            "properties": {
                "reactionTime": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "trialId": {
                                "type": "integer",
                            },
                            "condition": {
                                "type": "string",
                                "enum": [
                                    "Congruent",
                                    "Incongruent",
                                    "Neutral"
                                ]
                            },
                            "rtMs": {
                                "type": "number",
                                "minimum": 0,
                                "unit": "milliseconds"
                            },
                            "accuracy": {
                                "type": "boolean"
                            },
                            "responseKey": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "trialId",
                            "condition",
                            "rtMs",
                            "accuracy",
                            "responseKey"
                        ]
                    },
                },
                "interferenceScore": {
                    "type": "number",
                    "minimum": 0,
                    "unit": "milliseconds",
                    "description": "Computed interference score: RT(incongruent) - RT(congruent). Measures cognitive conflict."
                },
                "errorRate": {
                    "type": "object",
                    "properties": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100,
                        "unit": "%", 
                        "enum": ["congruent", "incongruent", "neutral"]
                    },
                    "required": [
                        "congruent",
                        "incongruent",
                        "neutral"
                    ]
                },
                "accuracyAdjustedRT": {
                    "type": "number",
                    "minimum": 0,
                    "unit": "milliseconds"
                }
            },
            "required": [
                "reactionTime",
                "interferenceScore",
                "errorRate"
            ]
        },
        "expectedBehavior": {
            "type": "object",
            "properties": {
                "rtPattern": {
                    "type": "string",
                    "enum": [
                        "incongruent > congruent",
                        "incongruent < congruent",
                        "no difference"
                    ],
                },
                "errorPattern": {
                    "type": "string",
                    "enum": [
                        "incongruent > congruent",
                        "incongruent < congruent",
                        "no difference"
                    ],
                },
                "robustness": {
                    "type": "boolean"
                }
            },
            "required": [
                "rtPattern",
                "errorPattern",
                "robustness"
            ]
        },
        "reliability": {
            "type": "object",
            "properties": {
                "type": "string",
                "enum": [
                        "low",
                        "moderate",
                        "high"
                    ],
                "enum": ["testRetestReliability", "individualDifferenceReliability"]                    
                }
            },
            "required": [
                "testRetestReliability",
                "individualDifferenceReliability"
            ]
        },
        "cognitiveConstructs": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "Selective attention",
                    "Executive control",
                    "Inhibitory control",
                    "Processing speed",
                    "Conflict monitoring"
                ]
            },
        },
        "dataAnalysis": {
            "type": "object",
            "properties": {
                "outlierExclusion": {
                    "type": "object",
                    "properties": {
                        "method": {
                            "type": "string",
                            "enum": [
                                "\u00b12SD",
                                "200ms-3000ms"
                            ],
                        },
                        "threshold": {
                            "type": "object",
                            "properties": {
                                "type": "number",
                                "minimum": 0,
                                "unit": "milliseconds"
                                "enum": ["max", "min"]
                            },
                            "required": [
                                "min",
                                "max"
                            ]
                        }
                    },
                    "required": [
                        "method",
                        "threshold"
                    ]
                },
                "incorrectTrialRemoval": {
                    "type": "boolean"
                },
                "statisticalModel": {
                    "type": "string",
                    "enum": [
                        "within-subject ANOVA",
                        "mixed-effects modeling",
                        "linear regression",
                        "Bayesian models"
                    ],
                }
            },
            "required": [
                "outlierExclusion",
                "incorrectTrialRemoval",
                "statisticalModel"
            ]
        },
        "validity": {
            "type": "object",
            "properties": {
                "constructValidity": {
                    "type": "string",
                    "enum": [
                        "strong",
                        "moderate",
                        "weak"
                    ],
                },
                "sensitivityToDysfunction": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "frontal lobe dysfunction",
                            "ADHD",
                            "depression",
                            "schizophrenia",
                            "aging",
                            "language proficiency"
                        ]
                    },
                }
            },
            "required": [
                "constructValidity",
                "sensitivityToDysfunction"
            ]
        },
        "neuroimaging": {
            "type": "object",
            "properties": {
                "eeg": {
                    "type": "object",
                    "properties": {
                        "setup": {
                            "type": "object",
                            "properties": {
                                "channels": {
                                    "type": "integer",
                                    "minimum": 32,
                                    "maximum": 128
                                },
                                "system": {
                                    "type": "string",
                                    "enum": [
                                        "10-20",
                                        "high-density"
                                    ],
                                },
                                "samplingRate": {
                                    "type": "integer",
                                    "minimum": 500,
                                    "maximum": 1000,
                                    "unit": "Hz"
                                },
                                "impedance": {
                                    "type": "number",
                                    "minimum": 0,
                                    "maximum": 10000,
                                    "unit": "k\u03a9"
                                },
                                "reference": {
                                    "type": "string",
                                    "enum": [
                                        "linked mastoids",
                                        "average reference"
                                    ],
                                },
                                "eogChannels": {
                                    "type": "integer",
                                    "minimum": 1
                                }
                            },
                            "required": [
                                "channels",
                                "system",
                                "samplingRate",
                                "impedance",
                                "reference",
                                "eogChannels"
                            ]
                        },
                        "eventMarkers": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "stimulus onset",
                                    "response onset",
                                    "accuracy coding"
                                ]
                            },
                        },
                        "keyComponents": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "component": {
                                        "type": "string",
                                        "enum": [
                                            "N200",
                                            "N450",
                                            "P300",
                                            "LPC"
                                        ]
                                    },
                                    "latencyRange": {
                                        "type": "object",
                                        "properties": {
                                            "type": "number",
                                            "unit": "milliseconds"
                                            "enum": ["min", "max"]
                                        },
                                        "required": [
                                            "min",
                                            "max"
                                        ]
                                    },
                                    "interpretation": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "component",
                                    "latencyRange",
                                    "interpretation"
                                ]
                            }
                        },
                        "expectedPatterns": {
                            "type": "object",
                            "properties": {
                                "incongruentVsCongruent": {
                                    "type": "string",
                                    "enum": [
                                        "larger N450 amplitude",
                                        "greater fronto-central activation",
                                        "increased theta power"
                                    ],
                                }
                            },
                            "required": [
                                "incongruentVsCongruent"
                            ]
                        }
                    },
                    "required": [
                        "setup",
                        "eventMarkers",
                        "keyComponents",
                        "expectedPatterns"
                    ]
                },
                "fmri": {
                    "type": "object",
                    "properties": {
                        "scanner": {
                            "type": "object",
                            "properties": {
                                "fieldStrength": {
                                    "type": "number",
                                    "minimum": 1,
                                    "maximum": 7,
                                    "unit": "Tesla",
                                    "enum": ["type": "3T"]
                                },
                                "tr": {
                                    "type": "number",
                                    "minimum": 2000,
                                    "maximum": 2500,
                                    "unit": "milliseconds"
                                },
                                "te": {
                                    "type": "number",
                                    "minimum": 10,
                                    "maximum": 50,
                                    "unit": "milliseconds"
                                },
                                "voxelSize": {
                                    "type": "number",
                                    "minimum": 1,
                                    "maximum": 5,
                                    "unit": "mm"
                                },
                                "coverage": {
                                    "type": "string",
                                    "enum": [
                                        "whole-brain",
                                        "targeted"
                                    ],
                                }
                            },
                            "required": [
                                "fieldStrength",
                                "tr",
                                "te",
                                "voxelSize",
                                "coverage"
                            ]
                        },
                        "design": {
                            "type": "string",
                            "enum": [
                                "event-related",
                                "block"
                            ],
                        },
                        "keyRegions": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "region": {
                                        "type": "string",
                                        "enum": [
                                            "Anterior Cingulate Cortex (ACC)",
                                            "Dorsolateral Prefrontal Cortex (DLPFC)",
                                            "Inferior Frontal Gyrus",
                                            "Parietal Cortex",
                                            "Basal Ganglia"
                                        ]
                                    },
                                    "functionalRole": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "region",
                                    "functionalRole"
                                ]
                            }
                        },
                        "expectedContrast": {
                            "type": "string",
                            "enum": [
                                "incongruent > congruent"
                            ],
                        }
                    },
                    "required": [
                        "scanner",
                        "design",
                        "keyRegions",
                        "expectedContrast"
                    ]
                },
                "connectivityAnalysis": {
                    "type": "object",
                    "properties": {
                        "fMRI": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "PPI analysis",
                                    "functional connectivity",
                                    "fronto-parietal network engagement"
                                ]
                            },
                        },
                        "EEG": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "theta-band coherence",
                                    "phase synchronization",
                                    "EEG-fMRI fusion"
                                ]
                            },
                            "description": "Advanced EEG connectivity analyses."
                        },
                        "effectiveConnectivity": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "DCM",
                                    "Granger causality",
                                    "dynamic causal modeling"
                                ]
                            },
                        }
                    },
                    "required": [
                        "fMRI",
                        "EEG",
                        "effectiveConnectivity"
                    ]
                },
                "behavioralNeuralCoupling": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "correlation between interference score and ACC activation",
                            "N450 amplitude vs. reaction time slowing",
                            "theta power increase vs. error likelihood",
                            "trial-by-trial conflict adaptation (Gratton effect)"
                        ]
                    },
                }
            },
            "required": [
                "eeg",
                "fmri",
                "connectivityAnalysis",
                "behavioralNeuralCoupling"
            ]
        },
        "neurocomputationalModeling": {
            "type": "object",
            "properties": {
                "modelType": {
                    "type": "string",
                    "enum": [
                        "Drift Diffusion Model (DDM)",
                        "Conflict Monitoring Model (Botvinick)",
                        "Parallel Processing with Inhibition"
                    ],
                },
                "keyVariables": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "drift rate",
                            "decision threshold",
                            "conflict signal strength",
                            "control gain modulation"
                        ]
                    },
                },
                "modelFit": {
                    "type": "object",
                    "properties": {
                        "fitMethod": {
                            "type": "string",
                            "enum": [
                                "maximum likelihood",
                                "Bayesian estimation"
                            ]
                        },
                        "goodnessOfFit": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1,
                            "description": "R\u00b2 or other fit metric."
                        }
                    },
                    "required": [
                        "fitMethod",
                        "goodnessOfFit"
                    ]
                }
            },
            "required": [
                "modelType",
                "keyVariables",
                "modelFit"
            ]
        },
        "clinicalApplications": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "ADHD research",
                    "depression (emotional Stroop bias)",
                    "schizophrenia (impaired conflict monitoring)",
                    "frontal lobe lesion studies",
                    "aging research (executive control decline)"
                ]
            },
      }
    },
    "required": [
        "taskType",
        "stimuli",
        "taskInstruction",
        "experimentalSettings",
        "instruments",
        "primaryOutputs",
        "expectedBehavior",
        "reliability",
        "cognitiveConstructs",
        "dataAnalysis",
        "validity",
        "neuroimaging",
        "neurocomputationalModeling",
        "clinicalApplications"
    ]
}
