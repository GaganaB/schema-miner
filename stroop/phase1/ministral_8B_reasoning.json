{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Stroop Task Process Schema",
    "type": "object",
    "properties": {
        "experiment": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "enum": [
                        "Standard", 
                        "Emotional", 
                        "Bilingual",
                    ], 
                },
                "purpose": {
                    "type": "string",
                     "enum": [
                        "Selective attention", 
                        "Executive Control"
                    ],
                },
                "population": {
                    "type": "object",
                    "properties": {
                        "age_range": {
                            "type": "object",
                            "properties": {
                                "min": {
                                    "type": "number",
                                    "minimum": 0
                                },
                                "max": {
                                    "type": "number",
                                    "minimum": 0
                                }
                            },
                            "default": {
                                "min": 18,
                                "max": 65
                            }
                        },
                        "size": {
                            "type": "integer",
                            "minimum": 20,
                            "maximum": 200, 
                            "default": 30
                        },
                        "clinical": {
                            "type": "boolean",
                            "enum": [
                                "ADHD", 
                                "depression"
                            ],
                        }
                    }
                },
                "task_instruction": {
                    "type": "object",
                    "properties": {
                        "response_mode": {
                            "type": "string",
                            "enum": [
                                "Verbal",
                                "Manual"
                            ]
                        },
                        "response_mapping": {
                            "type": "object",
                            "properties": {
                                "standard": {
                                    "type": "boolean",
                                },
                                "reverse": {
                                    "type": "boolean",
                                }
                            }
                        }
                    }
                },
                "stimuli": {
                    "type": "object",
                    "properties": {
                        "color_set": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "red",
                                    "blue",
                                    "green",
                                    "yellow",
                                    "black",
                                    "white"
                                ]
                            },
                            "minItems": 3,
                            "maxItems": 6
                        },
                        "conditions": {
                            "type": "string",
                            "enum": ["congruent", "incongruent", "neutral", "emotional"],
                        }, 
                            "default": {
                                "congruent": true,
                                "incongruent": true,
                                "neutral": true,
                                "emotional": false
                            }
                        },
                        "trial_count": {
                            "type": "integer",
                            "enum": ["congruent", "incongruent", "neutral", "emotional"],
                            "minimum": 20,
                            "maximum": 100, 
                                    "default": 20
                        },
                    }
                },
                "timing": {
                    "type": "object",
                    "properties": {
                        "stimulus_duration": {
                            "type": "number",
                            "enum":{
                                "type":"ms"
                            }
                            "minimum": 500,
                            "maximum": 2000, 
                            "default": 1000
                        },
                        "inter_trial_interval": {
                            "type": "number",
                            "enum":{
                                "type":"ms"
                            },
                            "minimum": 500,
                            "maximum": 1500,
                            "default": 1000,
                        },
                        "randomization": {
                            "type": "boolean",
                            "default": "true"
                        }
                    },
                },
                "environment": {
                    "type": "object",
                    "properties": {
                        "lighting": {
                            "type": "string",
                            "enum": [
                                "Controlled",
                                "Dim"
                            ]
                        },
                        "distraction_level": {
                            "type": "string",
                            "enum": [
                                "Minimal",
                                "Moderate"
                            ]
                        }
                    },
                    "default": {
                        "lighting": "Controlled",
                        "distraction_level": "Minimal"
                    }
                }
            }
        },
        "apparatus": {
            "type": "object",
            "properties": {
                "software": {
                    "type": "string",
                    "enum": [
                        "PsychoPy",
                        "E-Prime",
                        "MATLAB Psychtoolbox",
                        "Custom"
                    ]
                },
                "response_device": {
                    "type": "string",
                    "enum": [
                        "Keyboard",
                        "Response Pad",
                        "Voice Key"
                    ]
                },
                "display": {
                    "type": "object",
                    "description": "Display specifications.",
                    "properties": {
                        "luminance": {
                            "type": "number",
                            "minimum": 50,
                            "maximum": 200, 
                        },
                        "contrast": {
                            "type": "number",
                            "minimum": 0.1,
                            "maximum": 2.0
                        },
                        "resolution": {
                            "type": "string"
                        }
                    },
                    "default": {
                        "luminance": 100,
                        "contrast": 1.0
                    }
                }
            }
        },
        "outputs": {
            "type": "object",
            "properties": {
                "behavioral": {
                    "type": "object",
                    "properties": {
                        "reaction_time": {
                            "type": "object",
                            "properties": {
                                "type": "array",
                                "enum": ["congruent", "incongruent", "neutral", "emotional"],
                                 "items": {
                                        "type": "number",
                                        "minimum": 200,
                                        "maximum": 3000
                                    }
                            }
                        },
                        "error_rate": {
                            "type": "object",
                            "properties": {
                                "enum": ["congruent", "incongruent", "neutral"],
                                "items": {
                                        "type": "number",
                                        "minimum": 0,
                                        "maximum": 100,
                                        "default": 0,
                                    }
                            }
                        },
                        "interference_score": {
                            "type": "number",
                            "minimum": 0,
                            "default": 0
                        }
                    }
                },
                "data_analysis": {
                    "type": "object",
                    "properties": {
                        "outlier_removal": {
                            "type": "object",
                            "properties": {
                                "rt_threshold": {
                                    "type": "object",
                                    "properties": {
                                        "min": {
                                            "type": "number",
                                            "enum": ["type": "ms"],
                                            "minimum": 200,
                                            "default": 200
                                        },
                                        "max": {
                                            "type": "number",
                                            "enum": ["type": "ms"],
                                            "minimum": 200,
                                            "maximum": 3000,
                                            "default": 3000
                                        }
                                    }
                                },
                                "sd_threshold": {
                                    "type": "number",
                                    "minimum": 1,
                                    "maximum": 3,
                                    "default": 2
                                }
                            },
                            "default": {
                                "rt_threshold": {
                                    "min": 200,
                                    "max": 3000
                                },
                                "sd_threshold": 2
                            }
                        },
                        "analysis_method": {
                            "type": "string",
                            "enum": [
                                "ANOVA",
                                "Mixed-effects modeling",
                                "Regression",
                                "t-test"
                            ]
                        }
                    }
                }
            }
        },
        "neuroimaging": {
            "type": "object",
            "properties": {
                "eeg": {
                    "type": "object",
                    "properties": {
                        "cap": {
                            "type": "object",
                            "properties": {
                                "channels": {
                                    "type": "integer",
                                    "minimum": 32,
                                    "maximum": 128, 
                                    "default": 64
                                },
                                "system": {
                                    "type": "string",
                                    "enum": [
                                        "10-20",
                                        "High-density"
                                    ]
                                }
                            },
                            "default": {
                                "channels": 64
                            }
                        },
                        "sampling_rate": {
                            "type": "number",
                            "enum": ["type": "Hz"]
                            "minimum": 500,
                            "maximum": 1000, 
                            "default": 500
                        },
                        "reference": {
                            "type": "string",
                            "enum": [
                                "Linked mastoids",
                                "Average"
                            ]
                        },
                        "eog_channels": {
                            "type": "boolean",
                            "description": "Whether EOG channels are included for blink correction."
                        },
                        "event_markers": {
                            "type": "object",
                            "properties": {
                                "stimulus_onset": {
                                    "type": "object",
                                    "properties": {
                                        "type": "string",
                                        "enum": ["congruent", "incongruent", "neutral"],
                                    }
                                },
                                "response_onset": {
                                    "type": "string",
                                },
                                "accuracy": {
                                    "type": "string",
                                    "enum":[
                                        "correct", 
                                        "incorrect"
                                    ],
                                }
                            }
                        },
                        "components": {
                            "type": "object",
                            "properties": {
                                "n200": {
                                    "type": "object",
                                    "properties": {
                                        "latency": {
                                            "type": "object",
                                            "properties": {
                                                "min": {
                                                    "type": "number",
                                                    "minimum": 200,
                                                    "default": 200
                                                },
                                                "max": {
                                                    "type": "number",
                                                    "minimum": 200,
                                                    "maximum": 350,
                                                    "default": 350
                                                }
                                            }
                                        },
                                        "amplitude": {
                                            "type": "number",
                                            "enum":["type": "mV"]
                                        }
                                    }
                                },
                                "n450": {
                                    "type": "object",
                                    "properties": {
                                        "latency": {
                                            "type": "object",
                                            "properties": {
                                                "min": {
                                                    "type": "number",
                                                    "minimum": 350,
                                                    "default": 350
                                                },
                                                "max": {
                                                    "type": "number",
                                                    "minimum": 350,
                                                    "maximum": 500,
                                                    "default": 500
                                                }
                                            }
                                        },
                                        "amplitude": {
                                            "type": "number",
                                            "enum":["type": "mV"]
                                        }
                                    }
                                },
                                "p300": {
                                    "type": "object",
                                    "description": "P300 component (attention allocation).",
                                    "properties": {
                                        "latency": {
                                            "type": "object",
                                            "properties": {
                                                "min": {
                                                    "type": "number",
                                                    "minimum": 300,
                                                    "default": 300
                                                },
                                                "max": {
                                                    "type": "number",
                                                    "minimum": 300,
                                                    "maximum": 600,
                                                    "default": 600
                                                }
                                            }
                                        },
                                        "amplitude": {
                                            "type": "number",
                                            "enum":["type": "mV"]
                                        }
                                    }
                                },
                                "lpc": {
                                    "type": "object",
                                    "description": "Late Positive Component (control resolution).",
                                    "properties": {
                                        "latency": {
                                            "type": "object",
                                            "properties": {
                                                "min": {
                                                    "type": "number",
                                                    "minimum": 500,
                                                    "default": 500
                                                }
                                            }
                                        },
                                        "amplitude": {
                                            "type": "number",
                                            "enum":["type": "mV"]
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "fMRI": {
                    "type": "object",
                    "properties": {
                        "scanner": {
                            "type": "object",
                            "properties": {
                                "model": {
                                    "type": "string",
                                    "enum": [
                                        "3T",
                                        "7T"
                                    ]
                                },
                                "tr": {
                                    "type": "number",
                                    "enum":["type": "ms"],
                                    "minimum": 2000,
                                    "maximum": 2500,
                                    "default": 2000,
                                },
                                "te": {
                                    "type": "number",
                                    "enum":["type": "ms"],
                                    "minimum": 10,
                                    "maximum": 50,
                                    "default": 30
                                },
                                "voxel_size": {
                                    "type": "object",
                                    "enum":["type": "mm"],
                                    "properties": {
                                        "x": {
                                            "type": "number",
                                            "minimum": 2,
                                            "maximum": 3,
                                            "default": 3
                                        },
                                        "y": {
                                            "type": "number",
                                            "minimum": 2,
                                            "maximum": 3,
                                            "default": 3
                                        },
                                        "z": {
                                            "type": "number",
                                            "minimum": 2,
                                            "maximum": 3,
                                            "default": 3
                                        }
                                    }
                                }
                            },
                        },
                        "design": {
                            "type": "string",
                            "enum": [
                                "Event-related",
                                "Block"
                            ]
                        },
                        "regions_of_interest": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "Anterior Cingulate Cortex (ACC)",
                                    "Dorsolateral Prefrontal Cortex (DLPFC)",
                                    "Inferior Frontal Gyrus (IFG)",
                                    "Parietal Cortex",
                                    "Basal Ganglia"
                                ]
                            }
                        },
                        "contrast": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "cognitive_constructs": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "Selective attention",
                    "Executive control",
                    "Inhibitory control",
                    "Processing speed",
                    "Conflict monitoring",
                    "Emotional processing",
                    "Response inhibition",
                    "Language processing"
                ]
            }
        },
        "clinical_applications": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "ADHD",
                    "Depression",
                    "Schizophrenia",
                    "Frontal lobe lesions",
                    "Aging"
                ]
            }
        }
    },
    "required": [
        "experiment",
        "apparatus",
        "outputs"
    ],
    "default": {
        "experiment": {
            "population": {
                "age_range": {
                    "min": 18,
                    "max": 65
                },
                "size": 30,
                "clinical": false
            },
            "task_instruction": {
                "response_mode": "Verbal",
                "response_mapping": {
                    "standard": true,
                    "reverse": false
                }
            },
            "stimuli": {
                "color_set": [
                    "red",
                    "blue",
                    "green",
                    "yellow"
                ],
                "conditions": {
                    "congruent": true,
                    "incongruent": true,
                    "neutral": true,
                    "emotional": false
                },
                "trial_count": {
                    "congruent": 20,
                    "incongruent": 20,
                    "neutral": 20
                }
            },
            "timing": {
                "stimulus_duration": 1000,
                "inter_trial_interval": 1000,
                "randomization": true
            },
            "environment": {
                "lighting": "Controlled",
                "distraction_level": "Minimal"
            }
        },
        "apparatus": {
            "software": "PsychoPy",
            "response_device": "Keyboard",
            "display": {
                "luminance": 100,
                "contrast": 1.0
            }
        },
        "outputs": {
            "behavioral": {
                "reaction_time": {
                    "congruent": [],
                    "incongruent": [],
                    "neutral": []
                },
                "error_rate": {
                    "congruent": 0,
                    "incongruent": 0,
                    "neutral": 0
                },
                "interference_score": 0
            },
            "data_analysis": {
                "outlier_removal": {
                    "rt_threshold": {
                        "min": 200,
                        "max": 3000
                    },
                    "sd_threshold": 2
                },
                "analysis_method": "ANOVA"
            }
        }
    }
}
