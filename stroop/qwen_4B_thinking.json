{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "StroopTaskProcess",
    "type": "object",
    "properties": {
        "task_type": {
            "type": "string",
            "enum": [
                "behavioral",
                "neuroimaging"
            ],
        },
        "core_process": {
            "type": "object",
            "properties": {
                "stimuli": {
                    "type": "object",
                    "properties": {
                        "congruent": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "word": {
                                        "type": "string"
                                    },
                                    "ink_color": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "word",
                                    "ink_color"
                                ]
                            },
                            "minItems": 1,
                        },
                        "incongruent": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "word": {
                                        "type": "string"
                                    },
                                    "ink_color": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "word",
                                    "ink_color"
                                ]
                            },
                            "minItems": 1,
                        },
                        "neutral": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "symbol": {
                                        "type": "string"
                                    },
                                    "ink_color": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "symbol",
                                    "ink_color"
                                ]
                            },
                            "minItems": 1,
                        }
                    },
                },
                "task_instruction": {
                    "type": "string",
                 },
                "response_modality": {
                    "type": "string",
                    "enum": [
                        "verbal",
                        "manual"
                    ]
                }
            },
            "required": [
                "stimuli",
                "task_instruction",
                "response_modality"
            ]
        },
        "experimental_settings": {
            "type": "object",
            "properties": {
                "stimulus_duration": {
                    "type": "number",
                    "minimum": 500,
                    "maximum": 2000,
                    "unit": "ms",
                },
                "inter_trial_interval": {
                    "type": "number",
                    "minimum": 500,
                    "maximum": 1500,
                    "unit": "ms",
                },
                "trials_per_condition": {
                    "type": "integer",
                    "minimum": 20
                },
                "stimulus_order": {
                    "type": "string",
                    "enum": [
                        "randomized",
                        "counterbalanced"
                    ],
                },
                "environment": {
                    "type": "string",
                    "enum": ["controlled lighting", "minimal distraction"]
                }
            },
            "required": [
                "stimulus_duration",
                "inter_trial_interval",
                "trials_per_condition",
                "stimulus_order"
            ]
        },
        "instruments": {
            "type": "object",
            "properties": {
                "software": {
                    "type": "string",
                    "enum": ["PsychoPy", "E-Prime", "MATLAB Psychtoolbox"]
                },
                "response_device": {
                    "type": "string",
                    "enum": ["keyboard", "response pad", "voice key"]
                },
                "rt_precision": {
                    "type": "number",
                    "minimum": 0.001,
                    "unit": "ms"
                },
                "display": {
                    "type": "object",
                    "properties": {
                        "luminance": {
                            "type": "number",
                            "unit": "cd/m\u00b2"
                        },
                        "contrast": {
                            "type": "number",
                            "unit": "dimensionless"
                        }
                    },
                }
            },
            "required": [
                "software",
                "response_device",
                "rt_precision"
            ]
        },
        "outputs": {
            "type": "object",
            "properties": {
                "reaction_time": {
                    "type": "object",
                    "unit": "ms",
                    "properties": {
                        "type": "number",
                    },
                },
                "error_rate": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 100,
                    "unit": "%",
                },
                "interference_score": {
                    "type": "number",
                    "unit": "ms",
                    "description": "Calculated as RT(incongruent) - RT(congruent) (ms)"
                },
                "accuracy_adjusted_rt": {
                    "type": "number",
                    "unit": "ms"
                }
            },
            "required": [
                "reaction_time",
                "error_rate",
                "interference_score"
            ]
        },
        "neuroimaging": {
            "type": "object",
            "properties": {
                "eeg": {
                    "type": "object",
                    "properties": {
                        "channels": {
                            "type": "integer",
                            "minimum": 32,
                            "maximum": 128
                        },
                        "sampling_rate": {
                            "type": "number",
                            "minimum": 500,
                            "maximum": 1000,
                            "unit": "Hz"
                        },
                        "impedance": {
                            "type": "number",
                            "minimum": 5,
                            "maximum": 10000,
                            "unit": "k\u03a9"
                        },
                        "reference": {
                            "type": "string",
                            "enum": [
                                "linked_mastoids",
                                "average_reference"
                            ],
                        },
                        "eog_channels": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "event_markers": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "stimulus_onset",
                                    "response_onset",
                                    "accuracy"
                                ]
                            },
                        }
                    },
                },
                "fMRI": {
                    "type": "object",
                    "properties": {
                        "scanner": {
                            "type": "string",
                            "enum":["3T"]
                        },
                        "tr": {
                            "type": "number",
                            "minimum": 2000,
                            "maximum": 2500,
                            "unit": "ms"
                        },
                        "te": {
                            "type": "number",
                            "minimum": 20,
                            "maximum": 50,
                            "unit": "ms"
                        },
                        "voxel_size": {
                            "type": "number",
                            "minimum": 2,
                            "maximum": 3,
                            "unit": "mm",
                        },
                        "design": {
                            "type": "string",
                            "enum": [
                                "event_related",
                                "block_design"
                            ],
                        }
                    },
                }
            },
        },
        "analysis_parameters": {
            "type": "object",
            "properties": {
                "outlier_exclusion": {
                    "type": "object",
                    "properties": {
                        "rt_outliers": {
                            "type": "object",
                            "properties": {
                                "type": "number",
                                "unit": "ms"
                                "lower_bound": {
                                    "minimum": 200,
                                },
                                "upper_bound": {
                                    "maximum": 3000
                                }
                            },
                        }
                    },
                },
                "incorrect_trial_handling": {
                    "type": "string",
                    "enum": [
                        "exclude",
                        "adjust"
                    ],
                }
            },
        }
    },
    "required": [
        "task_type",
        "core_process",
        "experimental_settings",
        "instruments",
        "outputs",
        "analysis_parameters"
    ],
    "additionalProperties": false
}
