{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Stroop Task Process",
    "type": "object",
    "required": [
        "task_type",
        "stimuli",
        "task_instructions",
        "experimental_settings",
        "instruments",
        "outputs",
        "cognitive_constructs",
        "data_analysis",
        "validity",
        "neuroimaging",
        "clinical_applications"
    ],
    "properties": {
        "task_type": {
            "type": "string",
            "enum": [
                "Emotional Stroop",
                "Numerical Stroop",
                "Spatial Stroop",
                "Bilingual Stroop",
                "Color-Word Stroop"
            ]
        },
        "stimuli": {
            "type": "object",
            "properties": {
                "congruent": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "word": {
                                "type": "string"
                            },
                            "ink_color": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "word",
                            "ink_color"
                        ]
                    }
                },
                "incongruent": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "word": {
                                "type": "string"
                            },
                            "ink_color": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "word",
                            "ink_color"
                        ]
                    }
                },
                "neutral": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "stimulus": {
                                "type": "string"
                            },
                            "ink_color": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "stimulus",
                            "ink_color"
                        ]
                    }
                },
                "color_set": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "task_instructions": {
            "type": "object",
            "properties": {
                "primary_task": {
                    "type": "string",
                    "enum": [
                        "Name the ink color",
                        "Read the word"
                    ]
                },
                "response_modality": {
                    "type": "string",
                    "enum": [
                        "Verbal response",
                        "Manual keypress"
                    ]
                },
                "stimulus_description": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "Name the color of the ink for congruent stimuli.",
                            "Name the ink color for incongruent stimuli.",
                            "Read the word for neutral stimuli."
                        ]
                    }
                }
            }
        },
        "experimental_settings": {
            "type": "object",
            "properties": {
                "stimulus_duration": {
                    "type": "integer",
                    "minimum": 500,
                    "maximum": 2000
                },
                "iti": {
                    "type": "integer"
                }
            }
        },
        "neuroimaging": {
            "type": "object",
            "properties": {
                "behavior_neural_coupling": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "measure": {
                                "type": "string"
                            },
                            "description": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "measure",
                            "description"
                        ]
                    }
                },
                "neurocomputational_modeling": {
                    "type": "object",
                    "properties": {
                        "model_type": {
                            "type": "string",
                            "enum": [
                                "Parallel processing streams",
                                "Competitive inhibition dynamics",
                                "Drift diffusion modeling (DDM)",
                                "Conflict monitoring models (Botvinick framework)"
                            ]
                        },
                        "variables": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "enum": [
                                            "Drift rate",
                                            "Decision threshold",
                                            "Conflict signal strength",
                                            "Control gain modulation"
                                        ]
                                    },
                                    "description": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "name",
                                    "description"
                                ]
                            }
                        }
                    }
                },
                "clinical_applications": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "ADHD research",
                            "Depression",
                            "Schizophrenia",
                            "Frontal lobe lesion studies",
                            "Aging research"
                        ]
                    }
                }
            }
        }
    }
}
