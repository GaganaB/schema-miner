{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "StroopTaskProcess",
    "description": "Comprehensive schema representing a Stroop cognitive task process with experimental parameters, outputs, and neuroimaging extensions",
    "type": "object",
    "properties": {
        "variant_type": {
            "type": "string",
            "description": "Type of Stroop variant used in the experiment",
            "enum": [
                "standard",
                "emotional",
                "numerical",
                "spatial",
                "bilingual",
                "clinical"
            ],
            "default": "standard"
        },
        "stimuli": {
            "type": "object",
            "description": "Properties of experimental stimuli",
            "properties": {
                "congruent": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "description": "Color words displayed in matching ink color (e.g., 'RED' in red ink)"
                    }
                },
                "incongruent": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "description": "Color words displayed in non-matching ink color (e.g., 'RED' in blue ink)"
                    }
                },
                "neutral": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "description": "Non-color words/symbols in colored ink (e.g., 'XXXX' in green)"
                    }
                },
                "standard_colors": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "description": "Standard color set used (3-6 basic colors)"
                    },
                    "default": [
                        "red",
                        "blue",
                        "green",
                        "yellow"
                    ]
                }
            },
            "required": [
                "congruent",
                "incongruent",
                "neutral",
                "standard_colors"
            ]
        },
        "task_instruction": {
            "type": "object",
            "description": "Response mapping and modality instructions",
            "properties": {
                "response_mapping": {
                    "type": "string",
                    "description": "Primary instruction (e.g., 'name ink color', 'read word')",
                    "enum": [
                        "name_ink_color",
                        "read_word"
                    ],
                    "default": "name_ink_color"
                },
                "response_modality": {
                    "type": "string",
                    "description": "Response method (verbal or manual)",
                    "enum": [
                        "verbal",
                        "manual"
                    ],
                    "default": "verbal"
                }
            },
            "required": [
                "response_mapping",
                "response_modality"
            ]
        },
        "experimental_settings": {
            "type": "object",
            "description": "Experimental timing and trial structure",
            "properties": {
                "stimulus_duration": {
                    "type": "number",
                    "description": "Duration of stimulus presentation in milliseconds",
                    "minimum": 500,
                    "maximum": 2000,
                    "default": 1000
                },
                "inter_trial_interval": {
                    "type": "number",
                    "description": "Time between trials in milliseconds",
                    "minimum": 500,
                    "maximum": 1500,
                    "default": 1000
                },
                "trials_per_condition": {
                    "type": "number",
                    "description": "Number of trials per stimulus condition",
                    "minimum": 20,
                    "default": 30
                },
                "stimulus_order": {
                    "type": "string",
                    "description": "Order of stimulus presentation",
                    "enum": [
                        "randomized",
                        "counterbalanced"
                    ],
                    "default": "randomized"
                }
            },
            "required": [
                "stimulus_duration",
                "inter_trial_interval",
                "trials_per_condition"
            ]
        },
        "instruments": {
            "type": "object",
            "description": "Experimental apparatus and software",
            "properties": {
                "software": {
                    "type": "string",
                    "description": "Experimental software used (e.g., PsychoPy, E-Prime)"
                },
                "response_device": {
                    "type": "string",
                    "description": "Hardware for response collection (e.g., keyboard, response pad)"
                },
                "voice_key": {
                    "type": "boolean",
                    "description": "Whether voice key was used for verbal responses"
                },
                "rt_precision": {
                    "type": "string",
                    "description": "Reaction time measurement precision",
                    "default": "milliseconds"
                },
                "display_calibration": {
                    "type": "object",
                    "description": "Display calibration parameters",
                    "properties": {
                        "luminance": {
                            "type": "number",
                            "description": "Display luminance in cd/m\u00b2"
                        },
                        "contrast": {
                            "type": "number",
                            "description": "Display contrast ratio"
                        }
                    }
                }
            },
            "required": [
                "software",
                "response_device"
            ]
        },
        "outputs": {
            "type": "object",
            "description": "Primary dependent variables and metrics",
            "properties": {
                "reaction_time": {
                    "type": "object",
                    "description": "Average reaction time per condition in milliseconds",
                    "properties": {
                        "congruent": {
                            "type": "number",
                            "description": "Average RT for congruent trials"
                        },
                        "incongruent": {
                            "type": "number",
                            "description": "Average RT for incongruent trials"
                        },
                        "neutral": {
                            "type": "number",
                            "description": "Average RT for neutral trials"
                        }
                    },
                    "required": [
                        "congruent",
                        "incongruent",
                        "neutral"
                    ]
                },
                "error_rate": {
                    "type": "object",
                    "description": "Error rate per condition as percentage",
                    "properties": {
                        "congruent": {
                            "type": "number",
                            "description": "Error rate for congruent trials (%)"
                        },
                        "incongruent": {
                            "type": "number",
                            "description": "Error rate for incongruent trials (%)"
                        },
                        "neutral": {
                            "type": "number",
                            "description": "Error rate for neutral trials (%)"
                        }
                    },
                    "required": [
                        "congruent",
                        "incongruent",
                        "neutral"
                    ]
                },
                "interference_score": {
                    "type": "number",
                    "description": "Primary interference metric (RT_incongruent - RT_congruent) in milliseconds",
                    "minimum": 0
                },
                "accuracy_adjusted_rt": {
                    "type": "number",
                    "description": "Composite metric adjusting RT for accuracy (optional)"
                }
            },
            "required": [
                "reaction_time",
                "error_rate"
            ]
        },
        "cognitive_constructs": {
            "type": "array",
            "description": "Cognitive constructs measured by the task",
            "items": {
                "type": "string",
                "enum": [
                    "selective_attention",
                    "executive_control",
                    "inhibitory_control",
                    "processing_speed",
                    "conflict_monitoring"
                ]
            },
            "default": [
                "selective_attention",
                "executive_control",
                "inhibitory_control",
                "conflict_monitoring"
            ]
        },
        "data_analysis": {
            "type": "object",
            "description": "Analysis parameters and norms",
            "properties": {
                "rt_outlier_exclusion": {
                    "type": "object",
                    "description": "RT outlier exclusion criteria",
                    "properties": {
                        "method": {
                            "type": "string",
                            "enum": [
                                "sd",
                                "absolute"
                            ],
                            "default": "sd"
                        },
                        "threshold": {
                            "type": "number",
                            "description": "Threshold for outlier exclusion (SD units or ms)",
                            "default": 2
                        }
                    }
                },
                "incorrect_trial_removal": {
                    "type": "boolean",
                    "description": "Whether incorrect trials were excluded from RT analysis",
                    "default": true
                }
            },
            "required": [
                "rt_outlier_exclusion"
            ]
        },
        "neuroimaging": {
            "type": "object",
            "description": "Neuroimaging extensions (optional)",
            "properties": {
                "modalities": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "EEG",
                            "fMRI"
                        ]
                    }
                },
                "EEG": {
                    "type": "object",
                    "description": "EEG implementation parameters",
                    "properties": {
                        "channels": {
                            "type": "number",
                            "description": "Number of EEG channels",
                            "minimum": 32,
                            "default": 32
                        },
                        "sampling_rate": {
                            "type": "number",
                            "description": "EEG sampling rate in Hz",
                            "minimum": 500,
                            "default": 500
                        },
                        "impedance": {
                            "type": "number",
                            "description": "Electrode impedance in k\u03a9",
                            "minimum": 5,
                            "default": 5
                        },
                        "reference": {
                            "type": "string",
                            "description": "EEG reference method",
                            "default": "linked_mastoids"
                        },
                        "eog_channels": {
                            "type": "boolean",
                            "description": "Whether EOG channels were used for blink correction",
                            "default": true
                        },
                        "event_markers": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "stimulus_onset",
                                    "response_onset",
                                    "accuracy"
                                ]
                            },
                            "default": [
                                "stimulus_onset",
                                "response_onset",
                                "accuracy"
                            ]
                        },
                        "key_components": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "description": "EEG component name"
                                    },
                                    "latency_range": {
                                        "type": "array",
                                        "items": {
                                            "type": "number"
                                        },
                                        "description": "Latency range in milliseconds"
                                    },
                                    "interpretation": {
                                        "type": "string",
                                        "description": "Functional interpretation"
                                    }
                                },
                                "required": [
                                    "name",
                                    "latency_range",
                                    "interpretation"
                                ]
                            }
                        }
                    }
                },
                "fMRI": {
                    "type": "object",
                    "description": "fMRI implementation parameters",
                    "properties": {
                        "scanner": {
                            "type": "string",
                            "description": "MRI scanner strength",
                            "default": "3T"
                        },
                        "tr": {
                            "type": "number",
                            "description": "Repetition time in milliseconds",
                            "minimum": 2000,
                            "default": 2000
                        },
                        "te": {
                            "type": "number",
                            "description": "Echo time in milliseconds",
                            "default": 30
                        },
                        "voxel_size": {
                            "type": "string",
                            "description": "Voxel resolution in mm",
                            "default": "2x2x2"
                        },
                        "design": {
                            "type": "string",
                            "description": "Experimental design type",
                            "enum": [
                                "event_related",
                                "block"
                            ],
                            "default": "event_related"
                        },
                        "key_regions": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "region": {
                                        "type": "string",
                                        "description": "Brain region name"
                                    },
                                    "functional_role": {
                                        "type": "string",
                                        "description": "Functional role in Stroop task"
                                    }
                                },
                                "required": [
                                    "region",
                                    "functional_role"
                                ]
                            }
                        },
                        "expected_contrast": {
                            "type": "string",
                            "description": "Primary activation contrast",
                            "default": "incongruent > congruent"
                        }
                    }
                }
            }
        },
        "sample_characteristics": {
            "type": "object",
            "description": "Participant demographics and study design",
            "properties": {
                "age_range": {
                    "type": "object",
                    "description": "Participant age range",
                    "properties": {
                        "min": {
                            "type": "number",
                            "description": "Minimum age in years",
                            "minimum": 0
                        },
                        "max": {
                            "type": "number",
                            "description": "Maximum age in years",
                            "minimum": 0
                        }
                    },
                    "required": [
                        "min",
                        "max"
                    ],
                    "default": {
                        "min": 18,
                        "max": 65
                    }
                },
                "population": {
                    "type": "string",
                    "description": "Participant population type",
                    "enum": [
                        "adults",
                        "children",
                        "clinical",
                        "mixed"
                    ],
                    "default": "adults"
                },
                "sample_size": {
                    "type": "number",
                    "description": "Total number of participants",
                    "minimum": 20,
                    "default": 50
                }
            },
            "required": [
                "age_range",
                "population"
            ]
        }
    },
    "required": [
        "variant_type",
        "stimuli",
        "task_instruction",
        "experimental_settings",
        "instruments",
        "outputs",
        "cognitive_constructs",
        "data_analysis",
        "sample_characteristics"
    ],
    "additionalProperties": false
}

