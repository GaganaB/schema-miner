{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "StroopTaskProcess",
    "type": "object",
    "properties": {
        "variant_type": {
            "type": "string",
            "description": "Type of Stroop variant used in the experiment",
            "enum": [
                "standard",
                "emotional",
                "numerical",
                "spatial",
                "bilingual",
                "clinical"
            ],
            "default": "standard"
        },
        "stimuli": {
            "type": "object",
            "description": "Properties of experimental stimuli",
            "properties": {
                "type": "array",
                "items": {
                        "type": "string",
                },
                "enum": ["congruent", "incongruent", "neutral"],
                },
                "standard_colors": {
                    "type": "array",
                    "items": {
                        "type": "string",
                    },
                    "default": [
                        "red",
                        "blue",
                        "green",
                        "yellow"
                    ]
                }
            },
            "required": [
                "congruent",
                "incongruent",
                "neutral",
                "standard_colors"
            ]
        },
        "task_instruction": {
            "type": "object",
            "properties": {
                "response_mapping": {
                    "type": "string",
                    "enum": [
                        "name_ink_color",
                        "read_word"
                    ],
                    "default": "name_ink_color"
                },
                "response_modality": {
                    "type": "string",
                    "description": "Response method (verbal or manual)",
                    "enum": [
                        "verbal",
                        "manual"
                    ],
                    "default": "verbal"
                }
            },
            "required": [
                "response_mapping",
                "response_modality"
            ]
        },
        "experimental_settings": {
            "type": "object",
            "description": "Experimental timing and trial structure",
            "properties": {
                "stimulus_duration": {
                    "type": "number",
                    "units": "milliseconds",
                    "minimum": 500,
                    "maximum": 2000,
                    "default": 1000
                },
                "inter_trial_interval": {
                    "type": "number",
                    "units": "milliseconds",
                    "minimum": 500,
                    "maximum": 1500,
                    "default": 1000
                },
                "trials_per_condition": {
                    "type": "number",
                    "minimum": 20,
                    "default": 30
                },
                "stimulus_order": {
                    "type": "string",
                    "enum": [
                        "randomized",
                        "counterbalanced"
                    ],
                    "default": "randomized"
                }
            },
            "required": [
                "stimulus_duration",
                "inter_trial_interval",
                "trials_per_condition"
            ]
        },
        "instruments": {
            "type": "object",
            "description": "Experimental apparatus and software",
            "properties": {
                "software": {
                    "type": "string",
                    "enum": ["PsychoPy", "e-Prime"]
                },
                "response_device": {
                    "type": "string",
                    "enum": ["keyboard", "response pad"]
                },
                "voice_key": {
                    "type": "boolean",
                    "enum": ["verbal"]
                },
                "rt_precision": {
                    "type": "string",
                    "default": "milliseconds"
                },
                "display_calibration": {
                    "type": "object",
                    "properties": {
                        "type": "number", 
                        "enum": ["luminance", "contrast"],
                    }
                }
            },
            "required": [
                "software",
                "response_device"
            ]
        },
        "outputs": {
            "type": "object",
            "properties": {
                "reaction_time": {
                    "type": "object",
                    "units":"milliseconds",
                    "properties": {
                        "type": "number",
                        "enum": ["congruent", "incongruent", "neutral"]
                    },
                    "required": [
                        "congruent",
                        "incongruent",
                        "neutral"
                    ]
                },
                "error_rate": {
                    "type": "object",
                    "description": "Error rate per condition as percentage",
                    "properties": {
                        "type": "number",
                        "enum": ["congruent", "incongruent", "neutral"]
                    },
                    "required": [
                        "congruent",
                        "incongruent",
                        "neutral"
                    ]
                },
                "interference_score": {
                    "type": "number",
                    "units": "milliseconds",
                    "description": "Primary interference metric (RT_incongruent - RT_congruent)",
                    "minimum": 0
                },
                "accuracy_adjusted_rt": {
                    "type": "number",
                }
            },
            "required": [
                "reaction_time",
                "error_rate"
            ]
        },
        "cognitive_constructs": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "selective_attention",
                    "executive_control",
                    "inhibitory_control",
                    "processing_speed",
                    "conflict_monitoring"
                ]
            },
            "default": [
                "selective_attention",
                "executive_control",
                "inhibitory_control",
                "conflict_monitoring"
            ]
        },
        "data_analysis": {
            "type": "object"
            "properties": {
                "rt_outlier_exclusion": {
                    "type": "object",
                    "properties": {
                        "method": {
                            "type": "string",
                            "enum": [
                                "sd",
                                "absolute"
                            ],
                            "default": "sd"
                        },
                        "threshold": {
                            "type": "number",
                            "units": "SD units or ms"
                            "default": 2
                        }
                    }
                },
                "incorrect_trial_removal": {
                    "type": "boolean"
                    "default": true
                }
            },
            "required": [
                "rt_outlier_exclusion"
            ]
        },
        "neuroimaging": {
            "type": "object"
            "properties": {
                "modalities": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "EEG",
                            "fMRI"
                        ]
                    }
                },
                "EEG": {
                    "type": "object",
                    "properties": {
                        "channels": {
                            "type": "number",
                            "minimum": 32,
                            "default": 32
                        },
                        "sampling_rate": {
                            "type": "number",
                            "units": "Hz",
                            "minimum": 500,
                            "default": 500
                        },
                        "impedance": {
                            "type": "number",
                            "minimum": 5,
                            "default": 5
                        },
                        "reference": {
                            "type": "string",
                            "default": "linked_mastoids"
                        },
                        "eog_channels": {
                            "type": "boolean",
                            "default": true
                        },
                        "event_markers": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "stimulus_onset",
                                    "response_onset",
                                    "accuracy"
                                ]
                            },
                            "default": [
                                "stimulus_onset",
                                "response_onset",
                                "accuracy"
                            ]
                        },
                        "key_components": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "latency_range": {
                                        "type": "array",
                                        "items": {
                                            "type": "number"
                                        },
                                        "units": "milliseconds"
                                    },
                                    "interpretation": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "name",
                                    "latency_range",
                                    "interpretation"
                                ]
                            }
                        }
                    }
                },
                "fMRI": {
                    "type": "object",
                    "properties": {
                        "scanner": {
                            "type": "string",
                            "default": "3T"
                        },
                        "tr": {
                            "type": "number",
                            "units": "milliseconds",
                            "minimum": 2000,
                            "default": 2000
                        },
                        "te": {
                            "type": "number",
                            "units": "milliseconds",
                            "default": 30
                        },
                        "voxel_size": {
                            "type": "string",
                            "units": "mm",
                            "default": "2x2x2"
                        },
                        "design": {
                            "type": "string",
                            "enum": [
                                "event_related",
                                "block"
                            ],
                            "default": "event_related"
                        },
                        "key_regions": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "type": "string",
                                    "enum": ["regions", "functional_role"]
                                },
                                "required": [
                                    "region",
                                    "functional_role"
                                ]
                            }
                        },
                        "expected_contrast": {
                            "type": "string",
                            "default": "incongruent > congruent"
                        }
                    }
                }
            }
        },
        "sample_characteristics": {
            "type": "object",
            "properties": {
                "age_range": {
                    "type": "object",
                    "properties": {
                        "type": "number",
                        "minimum": 0, 
                        "enum": ["min", "max"]
                    },
                    "required": [
                        "min",
                        "max"
                    ],
                    "default": {
                        "min": 18,
                        "max": 65
                    }
                },
                "population": {
                    "type": "string",
                    "enum": [
                        "adults",
                        "children",
                        "clinical",
                        "mixed"
                    ],
                    "default": "adults"
                },
                "sample_size": {
                    "type": "number",
                    "minimum": 20,
                    "default": 50
                }
            },
            "required": [
                "age_range",
                "population"
            ]
        }
    },
    "required": [
        "variant_type",
        "stimuli",
        "task_instruction",
        "experimental_settings",
        "instruments",
        "outputs",
        "cognitive_constructs",
        "data_analysis",
        "sample_characteristics"
    ],
    "additionalProperties": false
}
